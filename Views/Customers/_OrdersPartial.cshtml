@model IReadOnlyList<VRLCRM.Models.Customers.CustomerTransactionRow>

<div class="card-toolbar d-flex flex-wrap justify-content-between align-items-center gap-3 px-4 pt-4 pb-2">
  <div class="d-flex align-items-center gap-2">
    <input type="text" class="form-control form-control-sm js-table-search" placeholder="Ara..." style="width:200px" />
  </div>
  <div class="d-flex align-items-center gap-2">
    <label class="text-body-secondary small mb-0">Göster:</label>
    <select class="form-select form-select-sm js-table-page-size" style="width:75px">
      <option value="10">10</option>
      <option value="25" selected>25</option>
      <option value="50">50</option>
    </select>
  </div>
</div>

<div class="table-responsive text-nowrap">
  <table class="table table-hover js-data-table mb-0">
    <thead>
      <tr>
        <th>No</th>
        <th>Tarih</th>
        <th>Tür</th>
        <th>Durum</th>
        <th>Tutar</th>
        <th></th>
      </tr>
    </thead>
    <tbody class="table-border-bottom-0">
      @if (!Model.Any())
      {
        <tr>
          <td colspan="6" class="text-center py-5 text-body-secondary">Kayıt bulunamadı.</td>
        </tr>
      }
      else
      {
        @foreach (var row in Model)
        {
          <tr>
            <td class="fw-semibold">@row.Number</td>
            <td>@row.Date.ToLocalTime().ToString("dd.MM.yyyy")</td>
            <td>
              @if (row.IsDirectInvoice)
              {
                <span class="badge bg-label-warning"><i class="ri-file-text-line me-1"></i>Fatura</span>
              }
              else
              {
                <span class="badge bg-label-primary"><i class="ri-shopping-bag-line me-1"></i>Sipariş</span>
              }
            </td>
            <td>
              <span class="badge bg-label-@row.StatusColor">@row.StatusLabel</span>
            </td>
            <td class="fw-semibold">@row.TotalAmount.ToString("N2") ₺</td>
            <td>
              @if (row.IsDirectInvoice)
              {
                <a asp-controller="Invoices" asp-action="Details" asp-route-id="@row.Id"
                   class="btn btn-sm btn-outline-primary">
                  <i class="ri-eye-line me-1"></i>Detay
                </a>
              }
              else
              {
                <a asp-controller="Orders" asp-action="Details" asp-route-id="@row.Id"
                   class="btn btn-sm btn-outline-primary">
                  <i class="ri-eye-line me-1"></i>Detay
                </a>
              }
            </td>
          </tr>
        }
      }
    </tbody>
  </table>
</div>
