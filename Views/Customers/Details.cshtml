@model Customer
@{
  ViewData["Title"] = "Müşteri Detayı";
}

<div class="row g-6">

  @* Sol: Müşteri bilgileri *@
  <div class="col-xl-4 col-lg-5">

    @* Profil kartı *@
    <div class="card mb-6">
      <div class="card-body pt-5 pb-4 text-center">
        <div class="avatar avatar-xl mx-auto mb-3">
          <span class="avatar-initial rounded-circle bg-label-primary" style="font-size:1.5rem;">
            @(string.IsNullOrWhiteSpace(Model.FirstName) ? "?" : Model.FirstName[0].ToString().ToUpperInvariant())
          </span>
        </div>
        <h5 class="mb-1">@Model.FullName</h5>
        @if (!string.IsNullOrWhiteSpace(Model.CompanyName))
        {
          <p class="text-body-secondary mb-2 small">@Model.CompanyName</p>
        }
        <partial name="_StatusBadge" model="Model.IsActive" />
      </div>
      <div class="card-footer d-flex justify-content-center gap-2 flex-wrap py-3">
        @if (Model.IsActive)
        {
          <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
            <i class="ri-pencil-line me-1"></i>Düzenle
          </a>
          <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
            <i class="ri-delete-bin-6-line me-1"></i>Pasife Al
          </a>
        }
        else
        {
          <form asp-action="Restore" asp-route-id="@Model.Id" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm">
              <i class="ri-refresh-line me-1"></i>Aktif Yap
            </button>
          </form>
          <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="ri-pencil-line me-1"></i>Düzenle
          </a>
        }
        <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
          <i class="ri-question-line"></i>
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
      </div>
    </div>

    @* Detay bilgileri *@
    <div class="card mb-6">
      <div class="card-header">
        <h6 class="mb-0">Müşteri Bilgileri</h6>
      </div>
      <div class="detail-info-strip" style="border-radius:0; border-left:0; border-right:0; border-bottom:0; margin-bottom:0;">
        <div class="detail-info-item">
          <div class="detail-info-label">Telefon</div>
          <div class="detail-info-value">@Model.PhoneNumber</div>
        </div>
        <div class="detail-info-item">
          <div class="detail-info-label">Kayıt Tarihi</div>
          <div class="detail-info-value">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</div>
        </div>
        <div class="detail-info-item">
          <div class="detail-info-label">Cari Borç</div>
          <div class="detail-info-value @(Model.Balance > 0 ? "text-danger" : "")">@Model.Balance.ToString("N2") ₺</div>
        </div>
      </div>
    </div>

    @* Adres *@
    <div class="card mb-6">
      <div class="card-header">
        <h6 class="mb-0">Adres</h6>
      </div>
      <div class="card-body small">
        @if (Model.Address is not null)
        {
          <p class="mb-1"><i class="ri-map-pin-line me-1 text-body-secondary"></i>@Model.Address.City / @Model.Address.District</p>
          <p class="mb-0 text-body-secondary">@Model.Address.AddressLine</p>
        }
        else
        {
          <p class="text-body-secondary mb-0">Adres girilmemiş.</p>
        }
      </div>
    </div>

    @* Notlar *@
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
      <div class="card">
        <div class="card-header">
          <h6 class="mb-0">Notlar</h6>
        </div>
        <div class="card-body small text-body-secondary">
          @Model.Notes
        </div>
      </div>
    }

  </div>

  @* Sağ: Cari hareketler *@
  <div class="col-xl-8 col-lg-7">
    <div class="card">
      <div class="card-header">
        <h6 class="mb-0"><i class="ri-exchange-line me-2 text-primary"></i>Cari Hareketler</h6>
      </div>
      <div id="transactions-container">
        <div class="d-flex justify-content-center align-items-center py-5">
          <div class="spinner-border spinner-border-sm text-primary me-2"></div>
          <span class="text-body-secondary small">Yükleniyor…</span>
        </div>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
  <script>
    (function () {
      fetch('/Customers/TransactionsPartial/@Model.Id')
        .then(function(r) { return r.ok ? r.text() : Promise.reject(r.status); })
        .then(function(html) {
          var container = document.getElementById('transactions-container');
          container.innerHTML = html;
          container.querySelectorAll('table.js-data-table').forEach(function(table) {
            if (window._initTableFilter) window._initTableFilter(table);
          });
        })
        .catch(function() {
          document.getElementById('transactions-container').innerHTML =
            '<p class="text-danger text-center py-4 small">Yüklenemedi.</p>';
        });
    })();
  </script>
  <script>
  (function () {
    const d = window.driver && window.driver.js && window.driver.js.driver;
    if (!d) return;
    const tour = d({
      animate: true, smoothScroll: true, allowClose: true,
      overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
      nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
      showProgress: true, progressText: '{{current}} / {{total}}',
      steps: [
        { element: '.avatar-initial', popover: { title: 'Müşteri Profili', description: 'Müşteri adı, firma ve durum bilgisi.', side: 'bottom' } },
        { element: '.detail-info-strip', popover: { title: 'Cari Borç', description: 'Satış faturası ve müşteriye ödeme borcu artırır; tahsilat borcu azaltır.', side: 'right' } },
        { element: '#transactions-container', popover: { title: 'Cari Hareketler', description: 'Siparişler, faturalar ve ödemeler tek tabloda listelenir.', side: 'top' } }
      ]
    });
    document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
  })();
  </script>
}
