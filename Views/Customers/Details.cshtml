@model Customer
@{
  ViewData["Title"] = "Müşteri Detayı";
}

<div class="row g-6">
  <div class="col-xl-8 col-lg-10">
    <div class="card mb-6">
      <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h5 class="mb-1">@Model.FullName</h5>
          <small class="text-body-secondary">Müşteri detay bilgileri</small>
        </div>
        <div class="d-flex gap-2">
          <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
            <i class="icon-base ri ri-pencil-line icon-16px me-1"></i> Düzenle
          </a>
          <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
            <i class="icon-base ri ri-delete-bin-6-line icon-16px me-1"></i> Sil
          </a>
          <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-6 mb-6">
          <div class="col-md-6">
            <h6 class="text-body-secondary mb-2">Ad Soyad</h6>
            <p class="mb-0">@Model.FullName</p>
          </div>
          <div class="col-md-6">
            <h6 class="text-body-secondary mb-2">Firma Adı</h6>
            <p class="mb-0">@(Model.CompanyName ?? "-")</p>
          </div>
          <div class="col-md-6">
            <h6 class="text-body-secondary mb-2">Telefon</h6>
            <p class="mb-0">@Model.PhoneNumber</p>
          </div>
          <div class="col-md-6">
            <h6 class="text-body-secondary mb-2">Kayıt Tarihi</h6>
            <p class="mb-0">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
          </div>
        </div>

        <h6 class="mb-3">Notlar</h6>
        <div class="border rounded p-4 mb-6 bg-label-secondary">
          @(string.IsNullOrWhiteSpace(Model.Notes) ? "Not girilmemiş." : Model.Notes)
        </div>

        <h6 class="mb-3">Adres</h6>
        @if (Model.Address is not null)
        {
          <ul class="list-unstyled mb-0">
            <li class="mb-2"><strong>İl:</strong> @Model.Address.City</li>
            <li class="mb-2"><strong>İlçe:</strong> @Model.Address.District</li>
            <li><strong>Açık Adres:</strong> @Model.Address.AddressLine</li>
          </ul>
        }
        else
        {
          <p class="text-body-secondary mb-0">Adres bilgisi girilmemiş.</p>
        }
      </div>
    </div>
  </div>
</div>
