@model CustomerFormViewModel

<div class="row g-4 mb-4">
  <div class="col-md-6">
    <label asp-for="FirstName" class="form-label"></label>
    <input asp-for="FirstName" class="form-control" placeholder="Ad" />
    <span asp-validation-for="FirstName" class="text-danger small"></span>
  </div>
  <div class="col-md-6">
    <label asp-for="LastName" class="form-label"></label>
    <input asp-for="LastName" class="form-control" placeholder="Soyad" />
    <span asp-validation-for="LastName" class="text-danger small"></span>
  </div>
</div>

<div class="mb-4">
  <label asp-for="CompanyName" class="form-label"></label>
  <input asp-for="CompanyName" class="form-control" placeholder="Firma adı" />
  <span asp-validation-for="CompanyName" class="text-danger small"></span>
</div>

<div class="mb-4">
  <label asp-for="PhoneNumber" class="form-label"></label>
  <div class="input-group">
    <span class="input-group-text"><i class="ri-phone-line"></i></span>
    <input asp-for="PhoneNumber" class="form-control phone-mask" placeholder="555 123 4567" />
  </div>
  <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
</div>

<div class="mb-4">
  <label asp-for="Notes" class="form-label"></label>
  <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Notlar"></textarea>
  <span asp-validation-for="Notes" class="text-danger small"></span>
</div>

<h6 class="mb-3 mt-2">Cari Hesap</h6>

<div class="mb-4">
  <label asp-for="CreditLimit" class="form-label"></label>
  <input asp-for="CreditLimit" class="form-control" placeholder="Limitsiz için boş bırakın" step="0.01" />
  <div class="form-text">Boş bırakılırsa müşteri için cari limit uygulanmaz.</div>
  <span asp-validation-for="CreditLimit" class="text-danger small"></span>
</div>

<h6 class="mb-3 mt-2">B2B Giriş (E-Ticaret)</h6>

<div class="row g-4 mb-4">
  <div class="col-md-6">
    <label asp-for="B2bLoginPhone" class="form-label"></label>
    <input asp-for="B2bLoginPhone" class="form-control phone-mask" placeholder="555 123 4567" autocomplete="off" />
    <div class="form-text">Müşteri B2B ekranına bu telefon numarası ile giriş yapar.</div>
    <span asp-validation-for="B2bLoginPhone" class="text-danger small"></span>
  </div>
  <div class="col-md-6">
    <label asp-for="Password" class="form-label"></label>
    <input asp-for="Password" class="form-control" placeholder="Şifre" autocomplete="new-password" />
    <div class="form-text">Mevcut şifreyi değiştirmek istemiyorsanız boş bırakın.</div>
    <span asp-validation-for="Password" class="text-danger small"></span>
  </div>
</div>

<h6 class="mb-3 mt-2">Adres Bilgileri</h6>

<div class="row g-4 mb-4">
  <div class="col-md-6">
    <label asp-for="City" class="form-label"></label>
    <input asp-for="City" class="form-control" placeholder="İl" />
    <span asp-validation-for="City" class="text-danger small"></span>
  </div>
  <div class="col-md-6">
    <label asp-for="District" class="form-label"></label>
    <input asp-for="District" class="form-control" placeholder="İlçe" />
    <span asp-validation-for="District" class="text-danger small"></span>
  </div>
</div>

<div class="mb-4">
  <label asp-for="AddressLine" class="form-label"></label>
  <textarea asp-for="AddressLine" class="form-control" rows="3" placeholder="Açık adres"></textarea>
  <span asp-validation-for="AddressLine" class="text-danger small"></span>
</div>
