@model IReadOnlyList<Customer>
@{
  ViewData["Title"] = "Müşteriler";
}

<div class="card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
    <h5 class="mb-0">Müşteri Listesi</h5>
    <a asp-action="Create" class="btn btn-primary">
      <i class="icon-base ri ri-add-line icon-16px me-1"></i>
      Yeni Müşteri
    </a>
  </div>
  <div class="card-body pb-0">
    <partial name="_TableToolbar" />
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover js-data-table">
      <thead>
        <tr>
          <th>Müşteri</th>
          <th>Firma</th>
          <th>Telefon</th>
          <th>Cari Borç</th>
          <th>İl / İlçe</th>
          <th>Durum</th>
          <th>İşlemler</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
        @if (!Model.Any())
        {
          <tr>
            <td colspan="7" class="text-center py-5 text-body-secondary">Henüz müşteri kaydı yok.</td>
          </tr>
        }
        else
        {
          @foreach (var customer in Model)
          {
            <tr class="@(customer.IsActive ? "" : "table-secondary")">
              <td>
                <div class="d-flex align-items-center">
                  <div class="avatar avatar-sm me-3">
                    <span class="avatar-initial rounded-circle bg-label-primary">
                      @(string.IsNullOrWhiteSpace(customer.FirstName) ? "?" : customer.FirstName[0].ToString().ToUpperInvariant())
                    </span>
                  </div>
                  <div>
                    <strong>@customer.FullName</strong>
                  </div>
                </div>
              </td>
              <td>@(customer.CompanyName ?? "-")</td>
              <td>@customer.PhoneNumber</td>
              <td>@customer.Balance.ToString("N2") ₺</td>
              <td>
                @if (customer.Address is not null)
                {
                  @($"{customer.Address.City} / {customer.Address.District}")
                }
                else
                {
                  <span>-</span>
                }
              </td>
              <td>
                <partial name="_StatusBadge" model="customer.IsActive" />
              </td>
              <td>
                <div class="dropdown">
                  <button type="button" class="btn p-0 dropdown-toggle hide-arrow shadow-none" data-bs-toggle="dropdown">
                    <i class="icon-base ri ri-more-2-line icon-18px"></i>
                  </button>
                  <div class="dropdown-menu">
                    <a class="dropdown-item" asp-action="Details" asp-route-id="@customer.Id">
                      <i class="icon-base ri ri-eye-line icon-18px me-1"></i> Detay
                    </a>
                    @if (customer.IsActive)
                    {
                      <a class="dropdown-item" asp-controller="Shop" asp-action="Index" asp-route-customerId="@customer.Id">
                        <i class="icon-base ri ri-shopping-cart-line icon-18px me-1"></i> Mağaza
                      </a>
                      <a class="dropdown-item" asp-action="Edit" asp-route-id="@customer.Id">
                        <i class="icon-base ri ri-pencil-line icon-18px me-1"></i> Düzenle
                      </a>
                      <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@customer.Id">
                        <i class="icon-base ri ri-delete-bin-6-line icon-18px me-1"></i> Pasife Al
                      </a>
                    }
                  </div>
                </div>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>
