@model IReadOnlyList<Customer>
@{
  ViewData["Title"] = "Müşteriler";
}

<div class="card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
    <h5 class="mb-0">Müşteri Listesi</h5>
    <div class="d-flex gap-2 align-items-center">
      <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
        <i class="ri-question-line"></i>
      </button>
      <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="ri-add-line me-1"></i>Yeni Müşteri
      </a>
    </div>
  </div>
  <div class="card-body pb-0">
    <partial name="_TableToolbar" />
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover js-data-table">
      <thead>
        <tr>
          <th>Müşteri</th>
          <th>Firma</th>
          <th>Telefon</th>
          <th>Cari Borç</th>
          <th>İl / İlçe</th>
          <th>Durum</th>
          <th></th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
        @if (!Model.Any())
        {
          <tr>
            <td colspan="7" class="text-center py-5 text-body-secondary">Henüz müşteri kaydı yok.</td>
          </tr>
        }
        else
        {
          @foreach (var customer in Model)
          {
            <tr class="@(customer.IsActive ? "" : "table-secondary")">
              <td>
                <div class="d-flex align-items-center">
                  <div class="avatar avatar-sm me-3">
                    <span class="avatar-initial rounded-circle bg-label-primary">
                      @(string.IsNullOrWhiteSpace(customer.FirstName) ? "?" : customer.FirstName[0].ToString().ToUpperInvariant())
                    </span>
                  </div>
                  <div>
                    <strong>@customer.FullName</strong>
                  </div>
                </div>
              </td>
              <td>@(customer.CompanyName ?? "-")</td>
              <td>@customer.PhoneNumber</td>
              <td>@customer.Balance.ToString("N2") ₺</td>
              <td>
                @if (customer.Address is not null)
                {
                  @($"{customer.Address.City} / {customer.Address.District}")
                }
                else
                {
                  <span>-</span>
                }
              </td>
              <td>
                <partial name="_StatusBadge" model="customer.IsActive" />
              </td>
              <td>
                <a asp-action="Details" asp-route-id="@customer.Id"
                   class="btn btn-sm btn-outline-primary">
                  <i class="ri ri-eye-line me-1"></i>Detay
                </a>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

@section PageScripts {
<script>
(function () {
  const d = window.driver && window.driver.js && window.driver.js.driver;
  if (!d) return;
  const tour = d({
    animate: true, smoothScroll: true, allowClose: true,
    overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
    nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
    showProgress: true, progressText: '{{current}} / {{total}}',
    steps: [
      {
        element: '.js-data-table',
        popover: {
          title: 'Müşteri Tablosu',
          description: 'Tüm müşteriler burada listelenir. Pasif müşteriler gri arka planla gösterilir.',
          side: 'top'
        }
      },
      {
        element: '.js-search-input',
        popover: {
          title: 'Hızlı Arama',
          description: 'Müşteri adı, firma veya telefon numarasıyla anında filtreleme yapabilirsiniz.',
          side: 'bottom'
        }
      },
      {
        element: 'th:nth-child(4)',
        popover: {
          title: 'Cari Borç',
          description: 'Müşterinin size olan bakiyesi. Fatura kesince artar, ödeme yapınca düşer. Detay sayfasından hareket geçmişini görebilirsiniz.',
          side: 'bottom'
        }
      },
      {
        element: 'a[href*="Create"]',
        popover: {
          title: 'Yeni Müşteri',
          description: 'Yeni bir müşteri kaydı açmak için bu butona tıklayın. Cari limit ve kredi bilgilerini buradan girebilirsiniz.',
          side: 'left'
        }
      }
    ]
  });
  document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
})();
</script>
}
