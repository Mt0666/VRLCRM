@model VRLCRM.Models.Payments.PaymentFormViewModel
@using VRLCRM.Domain.Enums
@{
  ViewData["Title"] = "Müşteriye Ödeme";
  var methodItems = new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
  {
    new() { Value = ((int)PaymentMethod.Cash).ToString(),         Text = "Nakit" },
    new() { Value = ((int)PaymentMethod.BankTransfer).ToString(), Text = "Havale / EFT" },
    new() { Value = ((int)PaymentMethod.CreditCard).ToString(),   Text = "Kredi Kartı" },
    new() { Value = ((int)PaymentMethod.Check).ToString(),        Text = "Çek" },
  };
}

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0 text-danger"><i class="ri-arrow-up-circle-line me-2"></i>Müşteriye Ödeme Yap</h5>
          <small class="text-body-secondary">Müşteriye iade veya ödeme kaydı — cari borç artar</small>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
          <i class="ri-arrow-left-line me-1"></i>Listeye Dön
        </a>
      </div>
      <div class="card-body">
        <form asp-action="CreateCustomerOutgoing" method="post">
          <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

          <div class="mb-3">
            <label asp-for="CustomerId" class="form-label"></label>
            <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select select2">
              <option value="">Müşteri seçin</option>
            </select>
            <span asp-validation-for="CustomerId" class="text-danger small"></span>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label asp-for="Amount" class="form-label">Tutar (₺)</label>
              <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" placeholder="0,00" />
              <span asp-validation-for="Amount" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="PaymentDate" class="form-label"></label>
              <input asp-for="PaymentDate" class="form-control" type="date" />
              <span asp-validation-for="PaymentDate" class="text-danger small"></span>
            </div>
          </div>

          <div class="mb-3">
            <label asp-for="Method" class="form-label"></label>
            <select asp-for="Method" asp-items="methodItems" class="form-select select2"></select>
            <span asp-validation-for="Method" class="text-danger small"></span>
          </div>

          <div class="mb-4">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Açıklama (opsiyonel)"></textarea>
            <span asp-validation-for="Notes" class="text-danger small"></span>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">
              <i class="ri-save-line me-1"></i>Ödemeyi Kaydet
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
  <partial name="_ValidationScriptsPartial" />
}
