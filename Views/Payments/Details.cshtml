@model VRLCRM.Domain.Entities.Payment
@using VRLCRM.Domain.Enums
@{
  ViewData["Title"] = "Fiş Detayı";
  bool isIncoming = Model.Type == PaymentType.Incoming;

  string MethodLabel(PaymentMethod m) => m switch
  {
    PaymentMethod.Cash         => "Nakit",
    PaymentMethod.BankTransfer => "Havale / EFT",
    PaymentMethod.CreditCard   => "Kredi Kartı",
    PaymentMethod.Check        => "Çek",
    _                          => m.ToString()
  };
}

<div class="row g-6">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div>
            <h5 class="mb-1">@Model.PaymentNumber</h5>
            <small class="text-body-secondary">
              @if (isIncoming)
              {
                <span class="badge bg-label-success me-1"><i class="ri-arrow-down-line me-1"></i>Tahsilat</span>
              }
              else
              {
                <span class="badge bg-label-danger me-1"><i class="ri-arrow-up-line me-1"></i>Ödeme</span>
              }
              @Model.PaymentDate.ToString("dd.MM.yyyy")
            </small>
          </div>
          <div class="d-flex gap-2 align-items-center">
            <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
              <i class="ri-question-line"></i>
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
              <i class="ri-arrow-left-line me-1"></i>Listeye Dön
            </a>
          </div>
        </div>
        @if (Model.IsActive)
        {
          <div class="d-flex gap-2 mt-3 pt-3 border-top">
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bu işlemi iptal etmek istediğinize emin misiniz? Bakiye geri alınacaktır.');">
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-outline-danger btn-sm">
                <i class="ri-close-circle-line me-1"></i>İptal Et
              </button>
            </form>
          </div>
        }
      </div>

      <div class="card-body">
        <div class="detail-info-strip">
          <div class="detail-info-item">
            <div class="detail-info-label">@(isIncoming ? "Müşteri" : "Tedarikçi")</div>
            <div class="detail-info-value">
              @if (isIncoming)
              {
                @(Model.Customer?.FullName ?? "-")
              }
              else
              {
                @(Model.Supplier?.CompanyName ?? "-")
              }
            </div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-label">Tutar</div>
            <div class="detail-info-value">@Model.Amount.ToString("N2") ₺</div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-label">Tarih</div>
            <div class="detail-info-value">@Model.PaymentDate.ToString("dd.MM.yyyy")</div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-label">Ödeme Yöntemi</div>
            <div class="detail-info-value">@MethodLabel(Model.Method)</div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-label">Durum</div>
            <div class="detail-info-value"><partial name="_StatusBadge" model="Model.IsActive" /></div>
          </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
          <p class="text-body-secondary"><i class="ri-sticky-note-line me-1"></i>@Model.Notes</p>
        }
      </div>
    </div>
  </div>
</div>

@section PageScripts {
<script>
(function () {
  const d = window.driver && window.driver.js && window.driver.js.driver;
  if (!d) return;
  const tour = d({
    animate: true, smoothScroll: true, allowClose: true,
    overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
    nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
    showProgress: true, progressText: '{{current}} / {{total}}',
    steps: [
      { element: '.detail-info-strip', popover: { title: 'İşlem Detayı', description: 'Fiş numarası, tarih, tür (tahsilat/ödeme), cari hesap ve ödeme yöntemi.', side: 'bottom' } },
      { element: 'form[action*="Cancel"] button', popover: { title: 'İşlemi İptal Et', description: 'Yanlış girilen tahsilat veya ödemeyi iptal eder. İptal edilince müşteri ya da tedarikçi bakiyesi otomatik eski haline döner.', side: 'bottom' } }
    ]
  });
  document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
})();
</script>
}
