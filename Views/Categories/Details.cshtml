@model Category
@{
  ViewData["Title"] = "Kategori Detayı";
}

<div class="row g-6">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div>
            <h5 class="mb-1">@Model.Name</h5>
            <small class="text-body-secondary">Kategori detayı</small>
          </div>
          <div class="d-flex flex-wrap gap-2 align-items-center">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
              <i class="ri-pencil-line me-1"></i>Düzenle
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
              <i class="ri-arrow-left-line me-1"></i>Listeye Dön
            </a>
          </div>
        </div>
        @if (Model.IsActive)
        {
          <div class="d-flex gap-2 mt-3 pt-3 border-top">
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
              <i class="ri-close-circle-line me-1"></i>Pasife Al
            </a>
          </div>
        }
      </div>
      <div class="card-body">
        <div class="detail-info-strip">
          <div class="detail-info-item">
            <div class="detail-info-label">Kategori Adı</div>
            <div class="detail-info-value">@Model.Name</div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-label">Oluşturulma Tarihi</div>
            <div class="detail-info-value">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
          </div>
          <div class="detail-info-item">
            <div class="detail-info-label">Durum</div>
            <div class="detail-info-value"><partial name="_StatusBadge" model="Model.IsActive" /></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
