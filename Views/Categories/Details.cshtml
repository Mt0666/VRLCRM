@model Category
@{
  ViewData["Title"] = "Kategori Detayı";
}

<div class="row">
  <div class="col-xl-6 col-lg-8">
    <div class="card mb-6">
      <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h5 class="mb-1">@Model.Name</h5>
          <small class="text-body-secondary">Kategori detayı</small>
        </div>
        <div class="d-flex gap-2">
          <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
            <i class="icon-base ri ri-pencil-line icon-16px me-1"></i> Düzenle
          </a>
          <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
            <i class="icon-base ri ri-delete-bin-6-line icon-16px me-1"></i> Sil
          </a>
          <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
        </div>
      </div>
      <div class="card-body">
        <h6 class="text-body-secondary mb-1">Kategori Adı</h6>
        <p class="mb-4">@Model.Name</p>
        <h6 class="text-body-secondary mb-1">Oluşturulma Tarihi</h6>
        <p class="mb-0">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
      </div>
    </div>
  </div>
</div>
