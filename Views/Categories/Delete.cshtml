@model Category
@{
  ViewData["Title"] = "Kategoriyi Pasife Al";
  var hasStockItems = ViewBag.HasStockItems as bool? ?? false;
}

<div class="row">
  <div class="col-md-8 col-lg-6">
    <div class="card border-danger mb-6">
      <div class="card-body">
        @if (hasStockItems)
        {
          <div class="alert alert-warning mb-4" role="alert">
            Bu kategoriye bağlı aktif stok kayıtları var. Pasife almadan önce stokları başka kategoriye taşıyın veya pasife alın.
          </div>
        }

        <div class="d-flex align-items-start mb-4">
          <span class="badge badge-center rounded-pill bg-danger me-3 p-3">
            <i class="icon-base ri ri-error-warning-line icon-24px"></i>
          </span>
          <div>
            <h5 class="mb-2">Kategoriyi pasif duruma almak istediğinize emin misiniz?</h5>
            <p class="mb-0 text-body-secondary">
              <strong>@Model.Name</strong> pasif olacak; veritabanından tamamen silinmeyecek.
            </p>
          </div>
        </div>

        <form asp-action="Delete" method="post">
          <input type="hidden" asp-for="Id" />
          <button type="submit" class="btn btn-danger me-3" @(hasStockItems ? "disabled" : null)>Evet, Pasife Al</button>
          <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
        </form>
      </div>
    </div>
  </div>
</div>
