@model IReadOnlyList<Category>
@{
  ViewData["Title"] = "Kategoriler";
}

<div class="card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
    <h5 class="mb-0">Kategori Listesi</h5>
    <a asp-action="Create" class="btn btn-primary">
      <i class="icon-base ri ri-add-line icon-16px me-1"></i>
      Yeni Kategori
    </a>
  </div>
  <div class="card-body pb-0">
    <partial name="_TableToolbar" />
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover js-data-table">
      <thead>
        <tr>
          <th>Kategori Adı</th>
          <th>Oluşturulma</th>
          <th>Durum</th>
          <th>İşlemler</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
        @if (!Model.Any())
        {
          <tr>
            <td colspan="4" class="text-center py-5 text-body-secondary">Henüz kategori yok.</td>
          </tr>
        }
        else
        {
          @foreach (var category in Model)
          {
            <tr class="@(category.IsActive ? "" : "table-secondary")">
              <td>
                <div class="d-flex align-items-center">
                  <span class="avatar avatar-sm me-3">
                    <span class="avatar-initial rounded bg-label-primary">
                      <i class="icon-base ri ri-folder-3-line"></i>
                    </span>
                  </span>
                  <strong>@category.Name</strong>
                </div>
              </td>
              <td>@category.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
              <td>
                <partial name="_StatusBadge" model="category.IsActive" />
              </td>
              <td>
                <div class="dropdown">
                  <button type="button" class="btn p-0 dropdown-toggle hide-arrow shadow-none" data-bs-toggle="dropdown">
                    <i class="icon-base ri ri-more-2-line icon-18px"></i>
                  </button>
                  <div class="dropdown-menu">
                    <a class="dropdown-item" asp-action="Details" asp-route-id="@category.Id">
                      <i class="icon-base ri ri-eye-line icon-18px me-1"></i> Detay
                    </a>
                    @if (category.IsActive)
                    {
                      <a class="dropdown-item" asp-action="Edit" asp-route-id="@category.Id">
                        <i class="icon-base ri ri-pencil-line icon-18px me-1"></i> Düzenle
                      </a>
                      <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@category.Id">
                        <i class="icon-base ri ri-delete-bin-6-line icon-18px me-1"></i> Pasife Al
                      </a>
                    }
                  </div>
                </div>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>
