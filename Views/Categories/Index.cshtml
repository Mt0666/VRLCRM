@model IReadOnlyList<Category>
@{
  ViewData["Title"] = "Kategoriler";
}

<div class="card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
    <h5 class="mb-0">Kategori Listesi</h5>
    <div class="d-flex gap-2 align-items-center">
      <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
        <i class="ri-question-line"></i>
      </button>
      <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="ri-add-line me-1"></i>Yeni Kategori
      </a>
    </div>
  </div>
  <div class="card-body pb-0">
    <partial name="_TableToolbar" />
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover js-data-table">
      <thead>
        <tr>
          <th>Kategori Adı</th>
          <th>Oluşturulma</th>
          <th>Durum</th>
          <th>İşlemler</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
        @if (!Model.Any())
        {
          <tr>
            <td colspan="4" class="text-center py-5 text-body-secondary">Henüz kategori yok.</td>
          </tr>
        }
        else
        {
          @foreach (var category in Model)
          {
            <tr class="@(category.IsActive ? "" : "table-secondary")">
              <td>
                <div class="d-flex align-items-center">
                  <span class="avatar avatar-sm me-3">
                    <span class="avatar-initial rounded bg-label-primary">
                      <i class="icon-base ri ri-folder-3-line"></i>
                    </span>
                  </span>
                  <strong>@category.Name</strong>
                </div>
              </td>
              <td>@category.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
              <td><partial name="_StatusBadge" model="category.IsActive" /></td>
              <td>
                <a asp-action="Details" asp-route-id="@category.Id"
                   class="btn btn-sm btn-icon btn-outline-secondary" title="Detay">
                  <i class="ri ri-eye-line"></i>
                </a>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

@section PageScripts {
<script>
(function () {
  const d = window.driver && window.driver.js && window.driver.js.driver;
  if (!d) return;
  const tour = d({
    animate: true, smoothScroll: true, allowClose: true,
    overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
    nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
    showProgress: true, progressText: '{{current}} / {{total}}',
    steps: [
      { element: '.js-data-table', popover: { title: 'Kategori Listesi', description: 'Ürünleri gruplamanızı sağlayan kategoriler burada yönetilir. Her ürünün bir kategorisi olabilir; raporlarda kategori bazlı analizler yapılabilir.', side: 'top' } },
      { element: '.js-search-input', popover: { title: 'Hızlı Arama', description: 'Kategori adıyla anında filtrele.', side: 'bottom' } },
      { element: 'a[href*="Create"]', popover: { title: 'Yeni Kategori', description: 'Yeni ürün grubu tanımlamak için tıklayın.', side: 'left' } }
    ]
  });
  document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
})();
</script>
}
