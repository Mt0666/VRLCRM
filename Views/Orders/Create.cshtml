@model OrderFormViewModel
@{
  ViewData["Title"] = "Yeni Sipariş";
}

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Yeni Sipariş</h5>
        <div class="d-flex gap-2 align-items-center">
          <button type="button" id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
            <i class="ri-question-line"></i>
          </button>
          <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Listeye Dön</a>
        </div>
      </div>
      <div class="card-body">
        <form asp-action="Create" method="post" id="orderForm">
          <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

          @* Cari + Notlar *@
          <div class="row g-3 mb-4">
            <div class="col-md-12">
              <label class="form-label">Cari Türü</label>
              <div class="d-flex gap-3">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="PartyType" id="partyCustomer" value="customer" checked="@(Model.PartyType != "supplier")" />
                  <label class="form-check-label" for="partyCustomer">Müşteri</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="PartyType" id="partySupplier" value="supplier" checked="@(Model.PartyType == "supplier")" />
                  <label class="form-check-label" for="partySupplier">Tedarikçi</label>
                </div>
              </div>
            </div>
            <div class="col-md-6" id="customerSelectWrap">
              <label asp-for="CustomerId" class="form-label"></label>
              <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select select2">
                <option value="">Müşteri seçin</option>
              </select>
              <span asp-validation-for="CustomerId" class="text-danger small"></span>
            </div>
            <div class="col-md-6" id="supplierSelectWrap" style="display:none;">
              <label asp-for="SupplierId" class="form-label"></label>
              <select asp-for="SupplierId" asp-items="Model.Suppliers" class="form-select select2">
                <option value="">Tedarikçi seçin</option>
              </select>
              <span asp-validation-for="SupplierId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Notes" class="form-label"></label>
              <input asp-for="Notes" class="form-control" />
            </div>
          </div>

          @* Ürün Ekleme Paneli *@
          <div class="card border mb-4">
            <div class="card-header py-2 d-flex justify-content-between align-items-center">
              <span class="fw-semibold small text-body"><i class="ri-add-circle-line me-1"></i>Ürün Ekle</span>
              <button type="button" id="scannerBtn" class="btn btn-sm btn-outline-info">
                <i class="ri-camera-line me-1"></i>Barkod Tara
              </button>
            </div>
            <div class="card-body">
              @* Kamera okuyucu alanı (varsayılan gizli) *@
              <div id="scannerWrapper" class="mb-3" style="display:none;">
                <div id="qr-reader" style="width:100%; max-width:500px; margin:0 auto; border-radius:0.375rem; overflow:hidden;"></div>
                <div class="d-flex justify-content-center gap-2 mt-2">
                  <button type="button" id="stopScannerBtn" class="btn btn-sm btn-outline-secondary">
                    <i class="ri-camera-off-line me-1"></i>Kamerayı Kapat
                  </button>
                  <button type="button" id="torchBtn" class="btn btn-sm btn-outline-warning" style="display:none;" title="Işık aç/kapat">
                    <i class="ri-flashlight-line"></i>
                  </button>
                </div>
              </div>
              @* Ekleme satırı *@
              <div class="row g-3 align-items-center">
                <div class="col-md-5">
                  <select id="productSelect" style="width:100%">
                    <option value=""></option>
                  </select>
                  <div id="productMessage" class="form-text text-danger mt-1"></div>
                </div>
                <div class="col-md-2">
                  <input type="number" id="scanQty" class="form-control" value="1" min="1" placeholder="Adet" />
                </div>
                <div class="col-md-2">
                  <input type="number" id="lineUnitPrice" class="form-control" step="0.01" min="0" placeholder="Satış Fiyatı" />
                </div>
                <div class="col-md-3">
                  <button type="button" id="addProductBtn" class="btn btn-primary w-100">
                    <i class="ri-add-line me-1"></i>Ekle
                  </button>
                </div>
              </div>
            </div>
          </div>

          @* Satır Tablosu *@
          <div class="table-responsive mb-0">
            <table class="table table-bordered table-sm align-middle js-lines-table" id="linesTable">
              <thead class="table-light">
                <tr>
                  <th>Ürün</th>
                  <th>Açıklama</th>
                  <th class="text-center" style="width:80px">Adet</th>
                  <th class="text-end" style="width:130px">Birim Fiyat</th>
                  <th class="text-center" style="width:80px">KDV %</th>
                  <th class="text-end" style="width:130px">Ara Toplam</th>
                  <th class="text-end" style="width:120px">KDV</th>
                  <th class="text-end" style="width:130px">Toplam</th>
                  <th style="width:50px"></th>
                </tr>
              </thead>
              <tbody id="linesBody">
                <tr id="emptyRow">
                  <td colspan="9" class="text-center text-body-secondary py-4">
                    <i class="ri-inbox-line me-1"></i>Henüz ürün eklenmedi.
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          @* Tutar Özeti *@
          <div class="d-flex justify-content-end mt-2 mb-4">
            <div class="order-totals-card">
              <div class="order-totals-row">
                <span>Ara Toplam</span>
                <span id="subTotal">0,00 ₺</span>
              </div>
              <div class="order-totals-row">
                <span>Toplam KDV</span>
                <span id="vatTotal">0,00 ₺</span>
              </div>
              <div class="order-totals-row align-items-center gap-2">
                <span>Sipariş İskontosu (%)</span>
                <input type="number" id="orderDiscountRate" name="DiscountRate" class="form-control form-control-sm text-end" value="0" min="0" max="100" step="0.01" style="width:110px" />
              </div>
              <div class="order-totals-row d-none" id="discountAmountRow">
                <span>İskonto Tutarı</span>
                <span id="discountAmount">0,00 ₺</span>
              </div>
              <div class="order-totals-grand">
                <span>Genel Toplam</span>
                <span id="grandTotal">0,00 ₺</span>
              </div>
            </div>
          </div>

          <div id="lineInputs"></div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">
              <i class="ri-check-line me-1"></i>Siparişi Onayla
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
  <partial name="_ValidationScriptsPartial" />
  <script src="/vendor/libs/html5-qrcode/html5-qrcode.min.js"></script>
  <script src="~/js/barcode-scanner.js" asp-append-version="true"></script>
  <script src="/js/form-draft-storage.js"></script>
  <script>
    const DRAFT_KEY = 'vrlcrm_draft_order_create';
    let lineIndex = 0;
    const lines = new Map();
    const productCache = new Map();
    let scannedProduct = false;
    let orderScanner = null;

    function persistDraft() {
      FormDraftStorage.save(DRAFT_KEY, {
        lines: Array.from(lines.entries()),
        discount: document.getElementById('orderDiscountRate').value
      });
    }

    function restoreDraft() {
      const draft = FormDraftStorage.load(DRAFT_KEY);
      if (!draft || !draft.lines) return;
      draft.lines.forEach(function(entry) { lines.set(entry[0], entry[1]); });
      if (draft.discount !== undefined) {
        document.getElementById('orderDiscountRate').value = draft.discount;
      }
      renderLines();
      rebuildHiddenInputs();
      updateTotals();
    }

    FormDraftStorage.bindFormFields(DRAFT_KEY, '#orderForm', ['CustomerId', 'SupplierId', 'Notes']);

    function toggleOrderParty() {
      var isSupplier = document.getElementById('partySupplier').checked;
      document.getElementById('customerSelectWrap').style.display = isSupplier ? 'none' : '';
      document.getElementById('supplierSelectWrap').style.display = isSupplier ? '' : 'none';
      if (isSupplier) {
        var customerSelect = document.getElementById('CustomerId');
        if (customerSelect) customerSelect.value = '';
      } else {
        var supplierSelect = document.getElementById('SupplierId');
        if (supplierSelect) supplierSelect.value = '';
      }
    }
    document.getElementById('partyCustomer').addEventListener('change', toggleOrderParty);
    document.getElementById('partySupplier').addEventListener('change', toggleOrderParty);
    toggleOrderParty();

    function updateTotals() {
      let sub = 0, vat = 0;
      lines.forEach(function(item) {
        const lineSub = item.qty * item.price;
        vat += lineSub * (item.vatRate / 100);
        sub += lineSub;
      });
      const rate = parseFloat(document.getElementById('orderDiscountRate').value) || 0;
      const gross = sub + vat;
      const discountAmt = gross * (Math.min(Math.max(rate, 0), 100) / 100);
      const grand = gross - discountAmt;
      const fmt = function(v) { return v.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' ₺'; };
      document.getElementById('subTotal').textContent = fmt(sub);
      document.getElementById('vatTotal').textContent = fmt(vat);
      document.getElementById('grandTotal').textContent = fmt(grand);
      var discountRow = document.getElementById('discountAmountRow');
      if (rate > 0) {
        discountRow.classList.remove('d-none');
        document.getElementById('discountAmount').textContent = fmt(discountAmt);
      } else {
        discountRow.classList.add('d-none');
      }
      persistDraft();
    }

    function renderLines() {
      const tbody = document.getElementById('linesBody');
      const emptyRow = document.getElementById('emptyRow');
      Array.from(tbody.querySelectorAll('tr:not(#emptyRow)')).forEach(function(r) { r.remove(); });

      if (lines.size === 0) {
        emptyRow.style.display = '';
        return;
      }
      emptyRow.style.display = 'none';

      const fmt = function(v) { return v.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' ₺'; };

      lines.forEach(function(item, stockId) {
        const row = document.createElement('tr');
        row.dataset.stockId = stockId;

        function refreshRowTotals() {
          const lineSub = item.qty * item.price;
          const lineVat = lineSub * (item.vatRate / 100);
          const lineTotal = lineSub + lineVat;
          row.querySelector('.line-sub').textContent = fmt(lineSub);
          row.querySelector('.line-vat').textContent = fmt(lineVat);
          row.querySelector('.line-total').textContent = fmt(lineTotal);
          rebuildHiddenInputs();
          updateTotals();
        }

        row.innerHTML =
          '<td data-label="Ürün">' + item.name + '</td>' +
          '<td data-label="Açıklama"><input type="text" class="form-control form-control-sm line-notes" value="' + (item.notes || '').replace(/"/g, '&quot;') + '" placeholder="Ürün açıklaması" /></td>' +
          '<td data-label="Adet" class="text-center"><input type="number" class="form-control form-control-sm line-qty text-center" value="' + item.qty + '" min="1" style="width:70px;margin:0 auto;" /></td>' +
          '<td data-label="Birim Fiyat" class="text-end" style="padding:4px 8px"><input type="number" class="form-control form-control-sm text-end line-price" value="' + item.price.toFixed(2) + '" step="0.01" min="0" style="width:110px;margin-left:auto" /></td>' +
          '<td data-label="KDV %" class="text-center">%' + item.vatRate + '</td>' +
          '<td data-label="Ara Toplam" class="text-end line-sub">' + fmt(item.qty * item.price) + '</td>' +
          '<td data-label="KDV" class="text-end line-vat">' + fmt(item.qty * item.price * (item.vatRate / 100)) + '</td>' +
          '<td data-label="Toplam" class="text-end fw-semibold line-total">' + fmt(item.qty * item.price * (1 + item.vatRate / 100)) + '</td>' +
          '<td data-label="" class="text-center"><button type="button" class="btn btn-sm btn-outline-danger remove-line py-0 px-1"><i class="ri-delete-bin-6-line"></i></button></td>';
        tbody.appendChild(row);

        row.querySelector('.line-qty').addEventListener('change', function() {
          const qty = parseInt(this.value, 10);
          if (!qty || qty <= 0) { this.value = item.qty; return; }
          item.qty = qty;
          refreshRowTotals();
        });
        row.querySelector('.line-price').addEventListener('change', function() {
          const price = parseFloat(this.value);
          if (isNaN(price) || price < 0) { this.value = item.price.toFixed(2); return; }
          item.price = price;
          refreshRowTotals();
        });
        row.querySelector('.line-notes').addEventListener('input', function() {
          item.notes = this.value;
          rebuildHiddenInputs();
          persistDraft();
        });
        row.querySelector('.remove-line').addEventListener('click', function() {
          lines.delete(stockId);
          renderLines();
          rebuildHiddenInputs();
          updateTotals();
        });
      });
    }

    function rebuildHiddenInputs() {
      const container = document.getElementById('lineInputs');
      container.innerHTML = '';
      lineIndex = 0;
      lines.forEach(function(item, stockId) {
        container.insertAdjacentHTML('beforeend',
          '<input type="hidden" name="Lines[' + lineIndex + '].StockItemId" value="' + stockId + '" />' +
          '<input type="hidden" name="Lines[' + lineIndex + '].StockName" value="' + item.name.replace(/"/g, '&quot;') + '" />' +
          '<input type="hidden" name="Lines[' + lineIndex + '].Quantity" value="' + item.qty + '" />' +
          '<input type="hidden" name="Lines[' + lineIndex + '].UnitPrice" value="' + item.price + '" />' +
          '<input type="hidden" name="Lines[' + lineIndex + '].Notes" value="' + (item.notes || '').replace(/"/g, '&quot;') + '" />');
        lineIndex++;
      });
    }

    function addSelectedProduct() {
      var stockId = tsProduct.getValue();
      var qty = parseInt(document.getElementById('scanQty').value, 10) || 1;
      var customPrice = parseFloat(document.getElementById('lineUnitPrice').value);
      var msg = document.getElementById('productMessage');
      msg.textContent = '';

      if (!stockId) { msg.textContent = 'Lütfen ürün seçin.'; return; }

      var product = productCache.get(stockId);
      if (!product) { msg.textContent = 'Ürün bilgisi bulunamadı.'; return; }

      var finalPrice = (!isNaN(customPrice) && customPrice >= 0) ? customPrice : product.price;
      var existing = lines.get(stockId);
      lines.set(stockId, {
        name: product.name,
        qty: (existing ? existing.qty : 0) + qty,
        price: finalPrice,
        vatRate: product.vatRate,
        notes: existing ? existing.notes : ''
      });

      renderLines();
      rebuildHiddenInputs();
      updateTotals();

      tsProduct.clear();
      tsProduct.clearOptions();
      document.getElementById('scanQty').value = 1;
      document.getElementById('lineUnitPrice').value = '';

      if (scannedProduct) {
        scannedProduct = false;
        setTimeout(function () { if (orderScanner) orderScanner.start(); }, 400);
      } else {
        // Ürün eklendikten sonra ürün arama alanına dön
        setTimeout(function() { tsProduct.focus(); }, 80);
      }
    }

    document.getElementById('addProductBtn').addEventListener('click', addSelectedProduct);
    // Adet'te Enter → Fiyat alanına geç
    document.getElementById('scanQty').addEventListener('keydown', function(e) {
      if (e.key !== 'Enter') return;
      e.preventDefault();
      var priceInput = document.getElementById('lineUnitPrice');
      if (priceInput) { priceInput.focus(); priceInput.select(); }
    });
    // Fiyat'ta Enter → ürün ekle (addSelectedProduct zaten ürün arama alanına döner)
    document.getElementById('lineUnitPrice').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); addSelectedProduct(); }
    });
    document.getElementById('orderDiscountRate').addEventListener('input', updateTotals);
    // Enter tuşu form göndermesini engelle (fiziksel barkod okuyucular Enter gönderiyor)
    document.getElementById('orderForm').addEventListener('keydown', function(e) {
      if (e.key !== 'Enter') return;
      if (e.target.tagName === 'TEXTAREA') return;
      if (e.target.type === 'submit' || e.target.tagName === 'BUTTON') return;
      e.preventDefault();
    });
    document.getElementById('orderForm').addEventListener('submit', function() {
      FormDraftStorage.clear(DRAFT_KEY);
    });

    restoreDraft();

    function focusQtyInput() {
      var qty = document.getElementById('scanQty');
      if (qty) { qty.focus(); qty.select(); }
    }

    function selectFromSearch(query) {
      var msg = document.getElementById('productMessage');
      return fetch('@Url.Action("SearchProduct", "Orders")' + '?term=' + encodeURIComponent(query))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.length) {
            if (msg) msg.textContent = 'Ürün bulunamadı: ' + query;
            return;
          }
          if (msg) msg.textContent = '';
          data.forEach(function(item) {
            var key = String(item.id);
            productCache.set(key, item);
            if (!tsProduct.options[key]) {
              tsProduct.addOption({
                id: key,
                text: item.name + (item.stockCode ? ' (' + item.stockCode + ')' : ''),
                barcode: item.barcode || ''
              });
            }
          });

          // Tam barkod/stok kodu eşleşmesi veya tek sonuç → Enter ile seç
          var match = data.find(function(item) { return item.barcode === query; })
            || data.find(function(item) { return item.stockCode === query; })
            || (data.length === 1 ? data[0] : null);

          if (!match) {
            tsProduct.setTextboxValue(query);
            tsProduct.refreshOptions(false);
            tsProduct.open();
            return;
          }

          tsProduct.setValue(String(match.id));
        })
        .catch(function() {
          if (msg) msg.textContent = 'Arama başarısız.';
        });
    }

    // ── TomSelect AJAX ürün arama ───────────────────────────────────────
    var tsProduct = new TomSelect('#productSelect', {
      valueField: 'id',
      labelField: 'text',
      searchField: ['text', 'barcode'],
      create: false,
      loadThrottle: 2000,
      shouldLoad: function(query) { return query.length > 0; },
      openOnFocus: false,
      selectOnTab: false,
      placeholder: 'Ürün adı, kodu veya barkod ile arayın…',
      onType: function(value) {
        if (!value.length) this.close();
      },
      load: function(query, callback) {
        if (!query.length) return callback();
        fetch('@Url.Action("SearchProduct", "Orders")' + '?term=' + encodeURIComponent(query))
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var results = data.map(function(item) {
              productCache.set(String(item.id), item);
              return {
                id: String(item.id),
                text: item.name + (item.stockCode ? ' (' + item.stockCode + ')' : ''),
                barcode: item.barcode || ''
              };
            });
            callback(results);
          })
          .catch(function() { callback(); });
      },
      onChange: function(value) {
        var priceInput = document.getElementById('lineUnitPrice');
        if (!priceInput) return;
        if (value) {
          var product = productCache.get(String(value));
          if (product && product.price != null) {
            priceInput.value = parseFloat(product.price).toFixed(2);
          }
        } else {
          priceInput.value = '';
        }
      },
      onItemAdd: function() {
        setTimeout(focusQtyInput, 50);
      },
      render: {
        no_results: function() { return '<div class="no-results">Ürün bulunamadı.</div>'; }
      }
    });

    // Enter: ürünü seç ve adete geç (yazarken otomatik seçim yok)
    setTimeout(function() {
      if (!tsProduct.control_input) return;
      tsProduct.control_input.addEventListener('keydown', function(e) {
        if (e.key !== 'Enter') return;

        e.preventDefault();
        e.stopImmediatePropagation();

        if (tsProduct.getValue()) {
          focusQtyInput();
          return;
        }

        // Dropdown açık ve satır seçiliyse onu al
        if (tsProduct.isOpen && tsProduct.activeOption) {
          var activeVal = tsProduct.activeOption.dataset.value;
          if (activeVal) {
            tsProduct.setValue(activeVal);
            return;
          }
        }

        var capturedText = this.value.trim();
        if (capturedText) selectFromSearch(capturedText);
      }, true);
    }, 100);

    // ── Barkod tarayıcı — ortak iOS-uyumlu modül (/js/barcode-scanner.js) ──
    orderScanner = VRLScanner.create({
      readerId: 'qr-reader',
      wrapperId: 'scannerWrapper',
      toggleBtnId: 'scannerBtn',
      stopBtnId: 'stopScannerBtn',
      torchBtnId: 'torchBtn',
      messageId: 'productMessage',
      idleLabel: '<i class="ri-camera-line me-1"></i>Barkod Tara',
      runningLabel: '<i class="ri-camera-off-line me-1"></i>Kamerayı Kapat',
      onDetected: async function (decodedText, scanner) {
        var msg = document.getElementById('productMessage');
        msg.textContent = '';
        tsProduct.setTextboxValue(decodedText);
        await selectFromSearch(decodedText);
        scannedProduct = true;
      }
    });
  </script>
  <script>
  (function () {
    const d = window.driver && window.driver.js && window.driver.js.driver;
    if (!d) return;
    const tour = d({
      animate: true, smoothScroll: true, allowClose: true,
      overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
      nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
      showProgress: true, progressText: '{{current}} / {{total}}',
      steps: [
        { element: '#orderForm select[name="CustomerId"]', popover: { title: 'Müşteri Seçimi', description: 'Siparişin hangi müşteriye ait olduğunu seçin. Listede sadece aktif müşteriler görünür.', side: 'bottom' } },
        { element: '#scannerBtn', popover: { title: 'Barkod Tara', description: 'Bu butona basınca cihazınızın kamerası açılır. Ürünün barkodunu kameraya gösterin — ürün otomatik olarak arama kutusuna eklenir.', side: 'bottom' } },
        { element: '#scannerWrapper', popover: { title: 'Kamera Görüntüsü', description: 'Barkodu bu alana getirin. Tarama başarılı olunca kamera kapanır ve ürün otomatik seçilir. "Taramayı Durdur" butonu ile kamerayı manuel kapatabilirsiniz.', side: 'top' } },
        { element: '#productSelect', popover: { title: 'Manuel Ürün Arama', description: 'Barkod taramak yerine ürün adıyla da arama yapabilirsiniz. Arama kutusuna yazmaya başlayın.', side: 'bottom' } },
        { element: '#scanQty', popover: { title: 'Miktar', description: 'Kaç adet ekleyeceğinizi girin. Varsayılan 1\'dir.', side: 'bottom' } },
        { element: '#addProductBtn', popover: { title: 'Kaleme Ekle', description: 'Seçili ürünü ve miktarı sipariş listesine ekler. Aynı ürünü birden fazla kez ekleyebilirsiniz.', side: 'bottom' } },
        { element: '#linesTable', popover: { title: 'Sipariş Kalemleri', description: 'Eklenen ürünler burada listelenir. Çöp kutusu ikonuna basarak satırı silebilirsiniz. KDV ve genel toplam otomatik hesaplanır.', side: 'top' } },
        { element: 'button[type="submit"]', popover: { title: 'Siparişi Kaydet', description: 'En az bir kalem ekledikten sonra siparişi kaydedebilirsiniz. Sipariş "Bekliyor" durumunda açılır, onaylandıktan sonra faturaya dönüştürülür.', side: 'top' } }
      ]
    });
    document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
  })();
