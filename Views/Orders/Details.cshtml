@model Order
@{
  ViewData["Title"] = "Sipariş Detayı";
}

<div class="row g-6">
  <div class="col-xl-10">
    <div class="card">
      <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h5 class="mb-1">@Model.OrderNumber</h5>
          <small class="text-body-secondary">@Model.Customer.FullName</small>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a asp-action="ExportPdf" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">PDF</a>
          <a asp-action="ExportExcel" asp-route-id="@Model.Id" class="btn btn-outline-success btn-sm">Excel</a>
          <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
          @if (Model.IsActive && Model.Status == OrderStatus.Approved && !Model.SalesInvoiceId.HasValue)
          {
            <form asp-action="ConvertToSalesInvoice" asp-route-id="@Model.Id" method="post">
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-primary btn-sm">Satış Faturasına Dönüştür</button>
            </form>
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Sipariş iptal edilecek. Stok ve cari hesap geri alınacak. Devam edilsin mi?');">
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-outline-danger btn-sm">İptal Et</button>
            </form>
          }
        </div>
      </div>
      <div class="card-body">
        <div class="row g-4 mb-6">
          <div class="col-md-3"><strong>Tarih:</strong> @Model.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
          <div class="col-md-3"><strong>Sipariş Durumu:</strong>
            @(Model.Status == OrderStatus.Approved ? "Onaylandı" : Model.Status == OrderStatus.Cancelled ? "İptal" : Model.Status.ToString())
          </div>
          <div class="col-md-3"><strong>Toplam:</strong> @Model.TotalAmount.ToString("N2") ₺</div>
          <div class="col-md-3"><strong>Kayıt Durumu:</strong> <partial name="_StatusBadge" model="Model.IsActive" /></div>
          @if (Model.SalesInvoiceId.HasValue)
          {
            <div class="col-12">
              <span class="badge bg-label-primary">Faturalandırıldı</span>
              @if (Model.SalesInvoice is not null)
              {
                <a asp-controller="Invoices" asp-action="Details" asp-route-id="@Model.SalesInvoiceId" class="ms-2">@Model.SalesInvoice.InvoiceNumber</a>
              }
            </div>
          }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
          <p class="mb-4"><strong>Not:</strong> @Model.Notes</p>
        }
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>Ürün</th>
                <th>Adet</th>
                <th>Birim Fiyat</th>
                <th>KDV (%)</th>
                <th>KDV Tutarı</th>
                <th>Toplam</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var line in Model.Lines)
              {
                <tr>
                  <td>@line.StockItem.Name</td>
                  <td>@line.Quantity</td>
                  <td>@line.UnitPrice.ToString("N2") ₺</td>
                  <td>%@line.VatRate.ToString("N0")</td>
                  <td>@line.VatAmount.ToString("N2") ₺</td>
                  <td>@line.LineTotal.ToString("N2") ₺</td>
                </tr>
              }
            </tbody>
            <tfoot>
              <tr>
                <th colspan="5" class="text-end">Ara Toplam:</th>
                <th>@Model.SubTotal.ToString("N2") ₺</th>
              </tr>
              <tr>
                <th colspan="5" class="text-end">Toplam KDV:</th>
                <th>@Model.VatTotal.ToString("N2") ₺</th>
              </tr>
              <tr>
                <th colspan="5" class="text-end">Genel Toplam:</th>
                <th>@Model.TotalAmount.ToString("N2") ₺</th>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
