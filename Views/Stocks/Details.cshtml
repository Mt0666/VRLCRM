@model StockItem
@{
  ViewData["Title"] = "Stok Detayı";
}

<div class="row g-6">
  <div class="col-xl-8 col-lg-10">
    <div class="card mb-6">
      <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h5 class="mb-1">@Model.Name</h5>
          <small class="text-body-secondary">@Model.StockCode</small>
        </div>
        <div class="d-flex gap-2">
          <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
            <i class="icon-base ri ri-pencil-line icon-16px me-1"></i> Düzenle
          </a>
          <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
            <i class="icon-base ri ri-delete-bin-6-line icon-16px me-1"></i> Sil
          </a>
          <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-6">
          <div class="col-md-4">
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
              <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border w-100" style="max-height: 240px; object-fit: cover;" />
            }
            else
            {
              <div class="d-flex align-items-center justify-content-center rounded border bg-label-secondary" style="height: 240px;">
                <i class="icon-base ri ri-image-line icon-48px text-body-secondary"></i>
              </div>
            }
          </div>
          <div class="col-md-8">
            <div class="row g-4 mb-4">
              <div class="col-sm-6">
                <h6 class="text-body-secondary mb-1">Kategori</h6>
                <p class="mb-0">@Model.Category.Name</p>
              </div>
              <div class="col-sm-6">
                <h6 class="text-body-secondary mb-1">Fiyat</h6>
                <p class="mb-0 fw-medium">@Model.Price.ToString("N2") ₺</p>
              </div>
              <div class="col-sm-6">
                <h6 class="text-body-secondary mb-1">Stok Adedi</h6>
                <p class="mb-0">@Model.StockQuantity</p>
              </div>
              <div class="col-sm-6">
                <h6 class="text-body-secondary mb-1">Kayıt Tarihi</h6>
                <p class="mb-0">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
              </div>
            </div>
            <h6 class="mb-2">Açıklama</h6>
            <div class="border rounded p-4 bg-label-secondary">
              @(string.IsNullOrWhiteSpace(Model.Description) ? "Açıklama girilmemiş." : Model.Description)
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
