@model StockFormViewModel

<div class="row g-6">
  <div class="col-md-6">
    <div class="form-floating form-floating-outline mb-6">
      <input asp-for="StockCode" class="form-control" placeholder="STK-001" />
      <label asp-for="StockCode"></label>
      <span asp-validation-for="StockCode" class="text-danger"></span>
    </div>
  </div>
  <div class="col-md-6">
    <div class="form-floating form-floating-outline mb-6">
      <input asp-for="Barcode" class="form-control" placeholder="Barkod" />
      <label asp-for="Barcode"></label>
      <span asp-validation-for="Barcode" class="text-danger"></span>
    </div>
  </div>
</div>

<div class="row g-6">
  <div class="col-md-6">
    <div class="form-floating form-floating-outline mb-6">
      <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
        <option value="">Kategori seçin</option>
      </select>
      <label asp-for="CategoryId"></label>
      <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>
    @if (!Model.Categories.Any())
    {
      <div class="form-text mb-4">
        Henüz kategori yok.
        <a asp-controller="Categories" asp-action="Create">Kategori oluştur</a>
      </div>
    }
  </div>
</div>

<div class="form-floating form-floating-outline mb-6">
  <input asp-for="Name" class="form-control" placeholder="Ürün adı" />
  <label asp-for="Name"></label>
  <span asp-validation-for="Name" class="text-danger"></span>
</div>

<div class="row g-6">
  <div class="col-md-4">
    <div class="form-floating form-floating-outline mb-6">
      <input asp-for="Price" class="form-control" placeholder="0.00" step="0.01" />
      <label asp-for="Price"></label>
      <span asp-validation-for="Price" class="text-danger"></span>
    </div>
  </div>
  <div class="col-md-4">
    <div class="form-floating form-floating-outline mb-6">
      <input asp-for="VatRate" class="form-control" placeholder="20" step="0.01" />
      <label asp-for="VatRate"></label>
      <span asp-validation-for="VatRate" class="text-danger"></span>
    </div>
  </div>
  <div class="col-md-4">
    <div class="form-floating form-floating-outline mb-6">
      <input asp-for="StockQuantity" class="form-control" placeholder="0" />
      <label asp-for="StockQuantity"></label>
      <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>
  </div>
</div>

<div class="mb-6">
  <label asp-for="ImageFile" class="form-label"></label>
  @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
  {
    <div class="mb-3">
      <img src="@Model.ImageUrl" alt="@Model.Name" class="rounded border" style="max-height: 120px;" />
    </div>
  }
  <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
  <div class="form-text">JPG, PNG, WEBP veya GIF. Maksimum 5 MB.</div>
  <span asp-validation-for="ImageFile" class="text-danger"></span>
</div>

<div class="form-floating form-floating-outline mb-6">
  <textarea asp-for="Description" class="form-control h-px-100" placeholder="Açıklama"></textarea>
  <label asp-for="Description"></label>
  <span asp-validation-for="Description" class="text-danger"></span>
</div>
