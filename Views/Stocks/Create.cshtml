@model StockFormViewModel
@{
  ViewData["Title"] = "Yeni Ürün";
}

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0">Yeni Ürün Ekle</h5>
          <small class="text-body-secondary">Stok listesine yeni ürün kaydı oluşturun</small>
        </div>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
          <i class="ri-arrow-left-line me-1"></i>Listeye Dön
        </a>
      </div>
      <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data" id="stockCreateForm">
          <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
          <partial name="_Form" model="Model" />
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="ri-save-line me-1"></i>Kaydet
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
  <partial name="_ValidationScriptsPartial" />
  <script src="/vendor/libs/html5-qrcode/html5-qrcode.min.js"></script>
  <script src="~/js/barcode-scanner.js" asp-append-version="true"></script>
  <script src="/js/form-draft-storage.js"></script>
  <script>
  (function () {
    const DRAFT_KEY = 'vrlcrm_draft_stock_create';
    FormDraftStorage.bindFormFields(DRAFT_KEY, '#stockCreateForm', [
      'Name', 'Barcode', 'Price', 'VatRate', 'StockQuantity',
      'StockCode', 'CategoryId', 'CriticalStockLevel', 'Description'
    ]);

    // ── Barkod tarayıcı — ortak iOS-uyumlu modül (/js/barcode-scanner.js) ──
    if (document.getElementById('stockScannerBtn') && window.VRLScanner) {
      VRLScanner.create({
        readerId: 'stock-qr-reader',
        wrapperId: 'stockScannerWrapper',
        toggleBtnId: 'stockScannerBtn',
        stopBtnId: 'stockStopScannerBtn',
        idleLabel: '<i class="ri-camera-line"></i>',
        runningLabel: '<i class="ri-camera-off-line"></i>',
        onDetected: function (decodedText) {
          var input = document.getElementById('stockBarcodeInput');
          input.value = decodedText;
          input.dispatchEvent(new Event('input'));
        }
      });
    }

    document.getElementById('stockCreateForm').addEventListener('submit', function () {
      FormDraftStorage.clear(DRAFT_KEY);
    });
  })();
  </script>
}
