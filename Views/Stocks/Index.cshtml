@model IReadOnlyList<StockItem>
@{
  ViewData["Title"] = "Ürünler";
}

<div class="card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
    <h5 class="mb-0">Ürün Listesi</h5>
    <div class="d-flex gap-2 align-items-center">
      <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
        <i class="ri-question-line"></i>
      </button>
      <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="ri-add-line me-1"></i>Yeni Ürün
      </a>
    </div>
  </div>
  <div class="card-body pb-0">
    <partial name="_TableToolbar" />
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover js-data-table">
      <thead>
        <tr>
          <th>Ürün</th>
          <th>Stok Kodu</th>
          <th>Kategori</th>
          <th>Fiyat</th>
          <th>Stok Adedi</th>
          <th>Durum</th>
          <th>İşlemler</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
        @if (!Model.Any())
        {
          <tr>
            <td colspan="7" class="text-center py-5 text-body-secondary">Henüz ürün kaydı yok.</td>
          </tr>
        }
        else
        {
          @foreach (var stock in Model)
          {
            <tr class="@(stock.IsActive ? "" : "table-secondary")">
              <td>
                <div class="d-flex align-items-center">
                  @if (!string.IsNullOrWhiteSpace(stock.ImageUrl))
                  {
                    <img src="@stock.ImageUrl" alt="@stock.Name" class="rounded me-3" style="width:40px; height:40px; object-fit:cover;" />
                  }
                  else
                  {
                    <div class="avatar avatar-sm me-3">
                      <span class="avatar-initial rounded bg-label-info">
                        <i class="icon-base ri ri-box-3-line"></i>
                      </span>
                    </div>
                  }
                  <strong>@stock.Name</strong>
                </div>
              </td>
              <td><span class="badge bg-label-secondary">@stock.StockCode</span></td>
              <td>@(stock.Category?.Name ?? "-")</td>
              <td>@stock.Price.ToString("N2") ₺</td>
              <td>
                @if (stock.StockQuantity <= 5)
                {
                  <span class="badge bg-label-danger">@stock.StockQuantity</span>
                }
                else if (stock.StockQuantity <= 20)
                {
                  <span class="badge bg-label-warning">@stock.StockQuantity</span>
                }
                else
                {
                  <span class="badge bg-label-success">@stock.StockQuantity</span>
                }
              </td>
              <td><partial name="_StatusBadge" model="stock.IsActive" /></td>
              <td>
                <a asp-action="Details" asp-route-id="@stock.Id"
                   class="btn btn-sm btn-icon btn-outline-secondary" title="Detay">
                  <i class="ri ri-eye-line"></i>
                </a>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

@section PageScripts {
<script>
(function () {
  const d = window.driver && window.driver.js && window.driver.js.driver;
  if (!d) return;
  const tour = d({
    animate: true, smoothScroll: true, allowClose: true,
    overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
    nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
    showProgress: true, progressText: '{{current}} / {{total}}',
    steps: [
      {
        element: '.js-data-table',
        popover: {
          title: 'Ürün Listesi',
          description: 'Tüm stok kalemleri burada listelenir. Kırmızı miktar = kritik stok (≤5), sarı = az stok (≤20).',
          side: 'top'
        }
      },
      {
        element: '.js-search-input',
        popover: {
          title: 'Hızlı Arama',
          description: 'Ürün adı, stok kodu veya kategoriye göre anında filtrele.',
          side: 'bottom'
        }
      },
      {
        element: 'th:nth-child(5)',
        popover: {
          title: 'Stok Miktarı',
          description: 'Anlık stok adedi. Satış faturası kesildiğinde azalır, alış faturasında artar. Tüm hareketleri Stok Hareketleri menüsünden takip edebilirsiniz.',
          side: 'bottom'
        }
      },
      {
        element: 'a[href*="Create"]',
        popover: {
          title: 'Yeni Ürün',
          description: 'Stok kartı oluşturmak için tıklayın. Birim fiyat, barkod ve kategori bilgilerini burada girebilirsiniz.',
          side: 'left'
        }
      }
    ]
  });
  document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
})();
</script>
}
