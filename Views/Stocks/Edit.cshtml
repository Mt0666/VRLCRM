@model StockFormViewModel
@{
  ViewData["Title"] = "Ürün Düzenle";
}

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0">Ürün Düzenle</h5>
          <small class="text-body-secondary">Ürün bilgilerini güncelleyin</small>
        </div>
        <div class="d-flex gap-2">
          <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">
            <i class="ri-eye-line me-1"></i>Detay
          </a>
          <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="ri-arrow-left-line me-1"></i>Listeye Dön
          </a>
        </div>
      </div>
      <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
          <input type="hidden" asp-for="Id" />
          <input type="hidden" asp-for="ImageUrl" />
          <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
          <partial name="_Form" model="Model" />
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="ri-save-line me-1"></i>Güncelle
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
  <partial name="_ValidationScriptsPartial" />
}
