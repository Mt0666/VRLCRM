@model StockFormViewModel
@{
  ViewData["Title"] = "Stok Düzenle";
}

<div class="row">
  <div class="col-xl-8 col-lg-10">
    <div class="card mb-6">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Stok Düzenle</h5>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Listeye Dön</a>
      </div>
      <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
          <input type="hidden" asp-for="Id" />
          <input type="hidden" asp-for="ImageUrl" />
          <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
          <partial name="_Form" model="Model" />
          <button type="submit" class="btn btn-primary me-3">Güncelle</button>
          <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info me-3">Detay</a>
          <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
        </form>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
  <partial name="_ValidationScriptsPartial" />
}
