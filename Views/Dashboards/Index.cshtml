@using VRLCRM.Domain.Enums
@model VRLCRM.Models.Dashboards.DashboardViewModel
@{
  ViewData["Title"] = "Dashboard";
  var now = DateTime.Now;
  var monthLabel = now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"));
}

<div class="row g-4">

  @* ══════════════════════════════════════════════════════════════
     SATIR 1 — 6 KPI kartı
  ══════════════════════════════════════════════════════════════ *@

  <div class="col-12" id="kpi-row">
    <div class="row g-4">

      @* Bu Ay Satış *@
      <div class="col-xl-2 col-md-4 col-6" id="kpi-sales">
        <div class="card h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="avatar avatar-sm">
                <div class="avatar-initial bg-label-primary rounded">
                  <i class="ri-line-chart-line"></i>
                </div>
              </div>
              <small class="text-body-secondary">@monthLabel</small>
            </div>
            <div class="mb-1 fw-semibold text-body-secondary" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Bu Ay Satış</div>
            <h5 class="mb-0 fw-bold">@Model.ThisMonthSales.ToString("N0") ₺</h5>
          </div>
        </div>
      </div>

      @* Bu Ay Alış *@
      <div class="col-xl-2 col-md-4 col-6">
        <div class="card h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="avatar avatar-sm">
                <div class="avatar-initial bg-label-info rounded">
                  <i class="ri-download-line"></i>
                </div>
              </div>
              <small class="text-body-secondary">@monthLabel</small>
            </div>
            <div class="mb-1 fw-semibold text-body-secondary" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Bu Ay Alış</div>
            <h5 class="mb-0 fw-bold">@Model.ThisMonthPurchases.ToString("N0") ₺</h5>
          </div>
        </div>
      </div>

      @* Açık Alacak *@
      <div class="col-xl-2 col-md-4 col-6">
        <div class="card h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="avatar avatar-sm">
                <div class="avatar-initial bg-label-success rounded">
                  <i class="ri-arrow-down-circle-line"></i>
                </div>
              </div>
              <small class="text-body-secondary">@Model.TotalCustomers müşteri</small>
            </div>
            <div class="mb-1 fw-semibold text-body-secondary" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Açık Alacak</div>
            <h5 class="mb-0 fw-bold @(Model.TotalReceivables > 0 ? "text-success" : "")">@Model.TotalReceivables.ToString("N0") ₺</h5>
          </div>
        </div>
      </div>

      @* Açık Borç *@
      <div class="col-xl-2 col-md-4 col-6">
        <div class="card h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="avatar avatar-sm">
                <div class="avatar-initial bg-label-warning rounded">
                  <i class="ri-arrow-up-circle-line"></i>
                </div>
              </div>
              <small class="text-body-secondary">tedarikçi</small>
            </div>
            <div class="mb-1 fw-semibold text-body-secondary" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Açık Borç</div>
            <h5 class="mb-0 fw-bold @(Model.TotalPayables > 0 ? "text-warning" : "")">@Model.TotalPayables.ToString("N0") ₺</h5>
          </div>
        </div>
      </div>

      @* Bekleyen Siparişler *@
      <div class="col-xl-2 col-md-4 col-6">
        <div class="card h-100">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="avatar avatar-sm">
                <div class="avatar-initial bg-label-secondary rounded">
                  <i class="ri-time-line"></i>
                </div>
              </div>
              <a asp-controller="Orders" asp-action="Index" class="small text-body-secondary">Gör</a>
            </div>
            <div class="mb-1 fw-semibold text-body-secondary" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Bekleyen Sipariş</div>
            <h5 class="mb-0 fw-bold">@Model.PendingOrdersCount <small class="fs-6 text-body-secondary fw-normal">adet</small></h5>
          </div>
        </div>
      </div>

      @* Faturasız Onaylı Sipariş *@
      <div class="col-xl-2 col-md-4 col-6" id="kpi-unbilled">
        <div class="card h-100 @(Model.UnbilledApprovedOrdersCount > 0 ? "border-danger border-2" : "")">
          <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="avatar avatar-sm">
                <div class="avatar-initial @(Model.UnbilledApprovedOrdersCount > 0 ? "bg-label-danger" : "bg-label-secondary") rounded">
                  <i class="ri-file-warning-line"></i>
                </div>
              </div>
              <a asp-controller="Orders" asp-action="Index" class="small text-body-secondary">Gör</a>
            </div>
            <div class="mb-1 fw-semibold text-body-secondary" style="font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">Faturasız Onaylı</div>
            <h5 class="mb-0 fw-bold @(Model.UnbilledApprovedOrdersCount > 0 ? "text-danger" : "")">
              @Model.UnbilledApprovedOrdersCount <small class="fs-6 text-body-secondary fw-normal">sipariş</small>
            </h5>
          </div>
        </div>
      </div>

    </div>
  </div>

  @* ══════════════════════════════════════════════════════════════
     SATIR 2 — Grafikler
  ══════════════════════════════════════════════════════════════ *@

  @* Son 6 Ay Trend *@
  <div class="col-xl-8" id="trend-col">
    <div class="card h-100" id="trend-card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0">Satış & Alış Trendi</h5>
          <small class="text-body-secondary">Son 6 aylık karşılaştırma</small>
        </div>
        <div class="d-flex gap-3 align-items-center">
          <span class="d-flex align-items-center gap-1 small"><span style="width:10px;height:10px;border-radius:2px;background:#696cff;display:inline-block;"></span>Satış</span>
          <span class="d-flex align-items-center gap-1 small"><span style="width:10px;height:10px;border-radius:2px;background:#03c3ec;display:inline-block;"></span>Alış</span>
        </div>
      </div>
      <div class="card-body p-3" style="min-height:280px;">
        <canvas id="trendChart"></canvas>
      </div>
    </div>
  </div>

  @* Bu Ay Tahsilat Yöntemi *@
  <div class="col-xl-4" id="payment-col">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0">Bu Ay Tahsilat</h5>
        <small class="text-body-secondary">Ödeme yöntemi dağılımı</small>
      </div>
      <div class="card-body p-3">
        @if (!Model.ThisMonthPaymentMethods.Any())
        {
          <div class="d-flex align-items-center justify-content-center h-100 text-body-secondary" style="min-height:200px;">
            <div class="text-center">
              <i class="ri-inbox-line" style="font-size:2rem;"></i>
              <p class="mt-2 mb-0 small">Bu ay tahsilat bulunmuyor</p>
            </div>
          </div>
        }
        else
        {
          <canvas id="paymentMethodChart" style="max-height:200px;"></canvas>
          <ul class="list-unstyled mt-3 mb-0">
            @foreach (var item in Model.ThisMonthPaymentMethods)
            {
              <li class="d-flex justify-content-between align-items-center py-1 border-bottom">
                <span class="small text-body-secondary">@item.Method</span>
                <span class="small fw-semibold">@item.Amount.ToString("N0") ₺</span>
              </li>
            }
          </ul>
        }
      </div>
    </div>
  </div>

  @* ══════════════════════════════════════════════════════════════
     SATIR 3 — Listeler
  ══════════════════════════════════════════════════════════════ *@

  @* En Yüksek Bakiyeli Müşteriler *@
  <div class="col-xl-4" id="debtors-col">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0">Açık Alacaklar</h5>
          <small class="text-body-secondary">En yüksek bakiyeli 5 müşteri</small>
        </div>
        <a asp-controller="Customers" asp-action="Index" class="small fw-medium">Tümü</a>
      </div>
      <div class="card-body p-0">
        @if (!Model.TopDebtorCustomers.Any())
        {
          <div class="p-4 text-center text-body-secondary">
            <i class="ri-checkbox-circle-line text-success" style="font-size:1.75rem;"></i>
            <p class="mt-2 mb-0 small">Açık alacak bulunmuyor</p>
          </div>
        }
        else
        {
          <ul class="list-unstyled mb-0">
            @foreach (var customer in Model.TopDebtorCustomers)
            {
              var pct = Model.TotalReceivables > 0 ? (int)Math.Round(customer.Balance / Model.TotalReceivables * 100) : 0;
              <li class="px-4 py-3 border-bottom">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <a asp-controller="Customers" asp-action="Details" asp-route-id="@customer.Id" class="fw-semibold text-body text-decoration-none">
                    @customer.FullName
                  </a>
                  <span class="fw-bold text-danger small">@customer.Balance.ToString("N0") ₺</span>
                </div>
                @if (!string.IsNullOrEmpty(customer.CompanyName))
                {
                  <small class="text-body-secondary">@customer.CompanyName</small>
                }
                <div class="progress mt-2" style="height:4px;">
                  <div class="progress-bar bg-danger" style="width:@pct%"></div>
                </div>
              </li>
            }
          </ul>
        }
      </div>
    </div>
  </div>

  @* Kritik Stok Uyarısı *@
  <div class="col-xl-4" id="stock-col">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0 @(Model.CriticalStocks.Any() ? "text-danger" : "")">
            @if (Model.CriticalStocks.Any())
            {
              <i class="ri-error-warning-line me-1"></i>
            }
            Kritik Stok
          </h5>
          <small class="text-body-secondary">Ürün bazlı kritik seviyenin altındakiler</small>
        </div>
        <a asp-controller="Stocks" asp-action="Index" class="small fw-medium">Tümü</a>
      </div>
      <div class="card-body p-0">
        @if (!Model.CriticalStocks.Any())
        {
          <div class="p-4 text-center text-body-secondary">
            <i class="ri-checkbox-circle-line text-success" style="font-size:1.75rem;"></i>
            <p class="mt-2 mb-0 small">Kritik stok yok</p>
          </div>
        }
        else
        {
          <div class="px-3 pt-3" style="height:180px;">
            <canvas id="criticalStockChart"></canvas>
          </div>
          <ul class="list-unstyled mb-0 border-top">
            @foreach (var item in Model.CriticalStocks)
            {
              <li class="d-flex justify-content-between align-items-center px-4 py-2 border-bottom">
                <div class="pe-2">
                  <a asp-controller="Stocks" asp-action="Details" asp-route-id="@item.Id" class="fw-semibold text-body text-decoration-none d-block small">
                    @item.Name
                  </a>
                  <small class="text-body-secondary">Kritik: @item.CriticalStockLevel adet</small>
                </div>
                <span class="badge bg-danger">@item.StockQuantity adet</span>
              </li>
            }
          </ul>
        }
      </div>
    </div>
  </div>

  @* Son Siparişler *@
  <div class="col-xl-4" id="orders-col">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-0">Son Siparişler</h5>
          <small class="text-body-secondary">En son 6 sipariş</small>
        </div>
        <a asp-controller="Orders" asp-action="Index" class="small fw-medium">Tümü</a>
      </div>
      <div class="card-body p-0">
        @if (!Model.RecentOrders.Any())
        {
          <div class="p-4 text-center text-body-secondary">
            <i class="ri-shopping-cart-line" style="font-size:1.75rem;"></i>
            <p class="mt-2 mb-0 small">Henüz sipariş yok</p>
          </div>
        }
        else
        {
          <ul class="list-unstyled mb-0">
            @foreach (var order in Model.RecentOrders)
            {
              var (badgeClass, statusLabel) = order.Status switch
              {
                OrderStatus.Approved  => ("bg-label-success", "Onaylı"),
                OrderStatus.Cancelled => ("bg-label-danger",  "İptal"),
                _                     => ("bg-label-warning", "Bekliyor")
              };
              <li class="d-flex justify-content-between align-items-center px-4 py-3 border-bottom">
                <div>
                  <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="fw-semibold text-body text-decoration-none d-block">
                    @order.OrderNumber
                  </a>
                  <small class="text-body-secondary">@order.Customer.FullName</small>
                </div>
                <div class="text-end">
                  <div class="fw-semibold small">@order.TotalAmount.ToString("N0") ₺</div>
                  <span class="badge @badgeClass">@statusLabel</span>
                </div>
              </li>
            }
          </ul>
        }
      </div>
    </div>
  </div>

</div>

@* Floating tour button *@
<button id="dashboard-tour-btn"
        title="Rehberi Başlat"
        style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:1040;width:44px;height:44px;border-radius:50%;border:none;background:#696cff;color:#fff;font-size:1.1rem;box-shadow:0 4px 14px rgba(105,108,255,.45);cursor:pointer;display:flex;align-items:center;justify-content:center;">
  <i class="ri-question-line"></i>
</button>

@section PageScripts {
  <script src="/vendor/libs/chart.js/chart.umd.min.js"></script>
  <script>
    const PALETTE = ['#696cff','#03c3ec','#71dd37','#ffab00','#ff3e1d','#8592a3','#26c6da','#a389d4'];

    // ── Son 6 Ay Satış & Alış Trendi (Grouped Bar) ──────────────
    const trendLabels    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last6MonthsTrend.Select(t => t.Month)));
    const trendSales     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last6MonthsTrend.Select(t => t.Sales)));
    const trendPurchases = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last6MonthsTrend.Select(t => t.Purchases)));

    new Chart(document.getElementById('trendChart'), {
      type: 'bar',
      data: {
        labels: trendLabels,
        datasets: [
          {
            label: 'Satış',
            data: trendSales,
            backgroundColor: 'rgba(105,108,255,0.85)',
            borderRadius: 5,
            borderSkipped: false
          },
          {
            label: 'Alış',
            data: trendPurchases,
            backgroundColor: 'rgba(3,195,236,0.75)',
            borderRadius: 5,
            borderSkipped: false
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ' ' + ctx.dataset.label + ': ' + Number(ctx.raw).toLocaleString('tr-TR', { minimumFractionDigits: 0 }) + ' ₺'
            }
          }
        },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 12 } } },
          y: {
            grid: { color: 'rgba(0,0,0,0.05)' },
            ticks: {
              font: { size: 11 },
              callback: v => v >= 1000 ? (v / 1000).toLocaleString('tr-TR') + 'K ₺' : v + ' ₺'
            }
          }
        }
      }
    });

    @if (Model.ThisMonthPaymentMethods.Any())
    {
      <text>
    // ── Tahsilat Yöntemi Dağılımı (Doughnut) ─────────────────
    const methodLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ThisMonthPaymentMethods.Select(m => m.Method)));
    const methodData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ThisMonthPaymentMethods.Select(m => m.Amount)));

    new Chart(document.getElementById('paymentMethodChart'), {
      type: 'doughnut',
      data: {
        labels: methodLabels,
        datasets: [{
          data: methodData,
          backgroundColor: PALETTE,
          borderWidth: 2,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ' ' + Number(ctx.raw).toLocaleString('tr-TR', { minimumFractionDigits: 0 }) + ' ₺'
            }
          }
        },
        cutout: '62%'
      }
    });
      </text>
    }

    @if (Model.CriticalStockChart.Any())
    {
      <text>
    const criticalLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CriticalStockChart.Select(x => x.Name)));
    const criticalQty    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CriticalStockChart.Select(x => x.Quantity)));
    const criticalLevels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CriticalStockChart.Select(x => x.CriticalLevel)));

    new Chart(document.getElementById('criticalStockChart'), {
      type: 'bar',
      data: {
        labels: criticalLabels,
        datasets: [
          {
            label: 'Mevcut Stok',
            data: criticalQty,
            backgroundColor: 'rgba(255,62,29,0.85)',
            borderRadius: 4,
            borderSkipped: false
          },
          {
            label: 'Kritik Seviye',
            data: criticalLevels,
            backgroundColor: 'rgba(133,146,163,0.35)',
            borderRadius: 4,
            borderSkipped: false
          }
        ]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ' ' + ctx.dataset.label + ': ' + ctx.raw + ' adet'
            }
          }
        },
        scales: {
          x: {
            grid: { color: 'rgba(0,0,0,0.05)' },
            ticks: { stepSize: 1, font: { size: 10 } }
          },
          y: { grid: { display: false }, ticks: { font: { size: 10 } } }
        }
      }
    });
      </text>
    }
  </script>

  <script>
  (function () {
    const TOUR_KEY = 'mvcrm_tour_done';
    const driverFn = window.driver && window.driver.js && window.driver.js.driver;
    if (!driverFn) return;

    const steps = [
      {
        element: '#kpi-row',
        popover: {
          title: 'Özet Göstergeler',
          description: 'Bu 6 kart, işletmenin anlık durumunu özetler: cari aya ait satış ve alış toplamları, müşteri alacakları, tedarikçi borçları ve sipariş durumları tek bakışta buradan izlenir.',
          side: 'bottom', align: 'start'
        }
      },
      {
        element: '#kpi-sales',
        popover: {
          title: 'Bu Ay Satış',
          description: 'Cari aya ait onaylanmış satış fatura toplamını gösterir. Geçmiş aylara kıymak için alttaki trend grafiğini kullanabilirsiniz.',
          side: 'bottom'
        }
      },
      {
        element: '#kpi-unbilled',
        popover: {
          title: 'Faturasız Onaylı Sipariş',
          description: 'Onaylanmış ancak henüz faturalanmamış siparişleri gösterir. <strong>Kırmızı çerçeve</strong> görünüyorsa bu siparişleri faturalamanız gerekiyor.',
          side: 'bottom'
        }
      },
      {
        element: '#trend-card',
        popover: {
          title: 'Satış & Alış Trendi',
          description: 'Son 6 ayın satış (mor) ve alış (mavi) karşılaştırması. Bir ayın üzerine geldiğinizde tam tutarı tooltip olarak görebilirsiniz.',
          side: 'top'
        }
      },
      {
        element: '#payment-col',
        popover: {
          title: 'Bu Ay Tahsilat',
          description: 'Bu ay yapılan tahsilatların nakit, havale/EFT, çek gibi yöntemlere göre dağılımını gösterir.',
          side: 'left'
        }
      },
      {
        element: '#debtors-col',
        popover: {
          title: 'Açık Alacaklar',
          description: 'Bakiyesi en yüksek 5 müşteri listelenir. Çubuğun uzunluğu, o müşterinin toplam alacak içindeki payını gösterir. İsme tıklayarak müşteri detayına gidebilirsiniz.',
          side: 'top'
        }
      },
      {
        element: '#stock-col',
        popover: {
          title: 'Kritik Stok',
          description: 'Her ürün için tanımlanan kritik seviyenin altına düşen ürünler grafikte gösterilir. Kırmızı çubuk mevcut stok, gri çubuk kritik seviyedir.',
          side: 'top'
        }
      },
      {
        element: '#orders-col',
        popover: {
          title: 'Son Siparişler',
          description: 'En son 6 siparişin durumu (Bekliyor / Onaylı / İptal) ve tutarı görünür. Sipariş numarasına tıklayarak detaya gidebilirsiniz.',
          side: 'top'
        }
      },
      {
        element: '#layout-menu',
        popover: {
          title: 'Sol Menü',
          description: 'Tüm modüllere sol menüden ulaşırsınız. Menü, iş akışınıza göre gruplandırılmıştır.',
          side: 'right', align: 'start'
        }
      },
      {
        element: '#menu-section-crm',
        popover: {
          title: 'CRM Modülü',
          description: '<b>Müşteriler</b> ve <b>Tedarikçiler</b> için cari hesap takibi; <b>Siparişler</b> için sipariş yönetimi; <b>Satış & Alış Faturaları</b> ile stok hareketini tetikleyen faturalama; <b>Kasa & Banka</b> ile tahsilat/ödeme kaydı.',
          side: 'right'
        }
      },
      {
        element: '#menu-section-stok',
        popover: {
          title: 'Stok Modülü',
          description: '<b>Ürünler</b>: stok kartları ve anlık miktar/fiyat bilgisi. <b>Kategoriler</b>: ürün grupları. <b>Stok Hareketleri</b>: fatura ve sipariş kaynaklı tüm giriş/çıkışların geçmişi.',
          side: 'right'
        }
      },
      {
        element: '#menu-section-raporlar',
        popover: {
          title: 'Raporlar & Yönetim',
          description: '<b>Satış Raporu</b>: tarih aralığına göre filtrelenebilir fatura özeti ve grafikler. <b>Stok Durum Raporu</b>: anlık stok değeri ve kritik ürün analizi.',
          side: 'right'
        }
      }
    ];

    function startTour() {
      const d = driverFn({
        animate: true,
        smoothScroll: true,
        allowClose: true,
        overlayOpacity: 0.4,
        stagePadding: 6,
        stageRadius: 8,
        nextBtnText: 'İleri →',
        prevBtnText: '← Geri',
        doneBtnText: 'Tamam',
        showProgress: true,
        progressText: '{{current}} / {{total}}',
        onDestroyed: () => localStorage.setItem(TOUR_KEY, '1'),
        steps
      });
      d.drive();
    }

    document.getElementById('dashboard-tour-btn').addEventListener('click', startTour);

    if (!localStorage.getItem(TOUR_KEY)) {
      setTimeout(startTour, 900);
    }
  })();
  </script>
}
