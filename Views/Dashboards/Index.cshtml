@using VRLCRM.Domain.Enums
@model VRLCRM.Models.Dashboards.DashboardViewModel
@{
  ViewData["Title"] = "Dashboard - VRLCRM";
}

<div class="row gy-6">

  <!-- İstatistik Kartları -->
  <div class="col-lg-12">
    <div class="card h-100">
      <div class="card-header">
        <div class="d-flex align-items-center justify-content-between">
          <h5 class="card-title m-0 me-2">Genel Durum</h5>
        </div>
        <p class="small mb-0">Sistemdeki genel özet veriler</p>
      </div>
      <div class="card-body pt-lg-10">
        <div class="row g-6">
          <div class="col-md-3 col-6">
            <div class="d-flex align-items-center">
              <div class="avatar">
                <div class="avatar-initial bg-primary rounded shadow-xs">
                  <i class="icon-base ri ri-money-dollar-circle-line icon-24px"></i>
                </div>
              </div>
              <div class="ms-3">
                <p class="mb-0">Toplam Satış (Fatura)</p>
                <h5 class="mb-0">@Model.TotalSalesAmount.ToString("C2")</h5>
              </div>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="d-flex align-items-center">
              <div class="avatar">
                <div class="avatar-initial bg-success rounded shadow-xs">
                  <i class="icon-base ri ri-group-line icon-24px"></i>
                </div>
              </div>
              <div class="ms-3">
                <p class="mb-0">Müşteriler</p>
                <h5 class="mb-0">@Model.TotalCustomers</h5>
              </div>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="d-flex align-items-center">
              <div class="avatar">
                <div class="avatar-initial bg-warning rounded shadow-xs">
                  <i class="icon-base ri ri-macbook-line icon-24px"></i>
                </div>
              </div>
              <div class="ms-3">
                <p class="mb-0">Stok Kalemleri</p>
                <h5 class="mb-0">@Model.TotalStockItems</h5>
              </div>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="d-flex align-items-center">
              <div class="avatar">
                <div class="avatar-initial bg-info rounded shadow-xs">
                  <i class="icon-base ri ri-shopping-cart-line icon-24px"></i>
                </div>
              </div>
              <div class="ms-3">
                <p class="mb-0">Toplam Sipariş Tutarı</p>
                <h5 class="mb-0">@Model.TotalOrdersAmount.ToString("C2")</h5>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!--/ İstatistik Kartları -->

  <!-- Kritik Stoklar -->
  <div class="col-xl-6">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2 text-danger">Kritik Stok Uyarısı (Son 8)</h5>
        <a asp-controller="Stocks" asp-action="Index" class="fw-medium">Tümünü Gör</a>
      </div>
      <div class="card-body">
        @if (!Model.CriticalStocks.Any())
        {
            <div class="alert alert-success">Kritik seviyede stok bulunmuyor.</div>
        }
        else
        {
            <ul class="p-0 m-0">
              @foreach(var item in Model.CriticalStocks)
              {
                  <li class="d-flex mb-4 align-items-center pb-2">
                    <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                      <div class="me-2">
                        <h6 class="mb-0">@item.Name</h6>
                        <p class="mb-0 small text-muted">@item.StockCode</p>
                      </div>
                      <h6 class="text-danger mb-0">@item.StockQuantity Adet Kaldı</h6>
                    </div>
                  </li>
              }
            </ul>
        }
      </div>
    </div>
  </div>
  <!--/ Kritik Stoklar -->

  <!-- Son Siparişler -->
  <div class="col-xl-6">
    <div class="card overflow-hidden h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title m-0 me-2">Son Siparişler</h5>
        <a asp-controller="Orders" asp-action="Index" class="fw-medium">Tümünü Gör</a>
      </div>
      <div class="table-responsive">
        <table class="table table-sm">
          <thead>
            <tr>
              <th class="text-truncate">Sipariş No</th>
              <th class="text-truncate">Müşteri</th>
              <th class="text-truncate">Tutar</th>
              <th class="text-truncate">Durum</th>
            </tr>
          </thead>
          <tbody>
            @foreach(var order in Model.RecentOrders)
            {
                <tr>
                  <td class="text-truncate"><a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id">@order.OrderNumber</a></td>
                  <td class="text-truncate">@order.Customer.FullName</td>
                  <td class="text-truncate">@order.TotalAmount.ToString("C2")</td>
                  <td>
                    @if (order.Status == OrderStatus.Approved)
                    {
                        <span class="badge bg-label-success rounded-pill">Onaylandı</span>
                    }
                    else if (order.Status == OrderStatus.Cancelled)
                    {
                        <span class="badge bg-label-danger rounded-pill">İptal</span>
                    }
                    else
                    {
                        <span class="badge bg-label-warning rounded-pill">Bekliyor</span>
                    }
                  </td>
                </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <!--/ Son Siparişler -->

</div>
