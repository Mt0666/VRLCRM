@using VRLCRM.Domain.Constants
@{
  string? currentPage = ViewContext.HttpContext.Request.Path;
  var isAdmin = User.IsInRole(AppRoles.Admin);
  var homeController = isAdmin ? "Dashboards" : "Orders";
}

<!-- Menu -->
<aside id="layout-menu" class="layout-menu menu-vertical menu">

  <div class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
    <a asp-controller="@homeController" asp-action="Index" class="app-brand-link gap-xl-0 gap-2">
      <span class="app-brand-logo demo me-1">
        @await Html.PartialAsync("../_Partials/_Macros")
      </span>
      <span class="app-brand-text demo menu-text fw-semibold ms-2">@TempData.Peek("appName")</span>
    </a>

    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
      <i class="menu-toggle-icon d-xl-inline-block align-middle"></i>
    </a>
  </div>

  <div class="menu-inner-shadow"></div>

  <ul class="menu-inner py-1">

    @if (isAdmin)
    {
      <!-- Ana Sayfa -->
      <li class='menu-item@(currentPage.EndsWith("/") || currentPage.StartsWith("/Dashboards") ? " active" : "")'>
        <a asp-controller="Dashboards" asp-action="Index" class="menu-link">
          <i class="menu-icon icon-base ri ri-home-smile-line"></i>
          <div>Ana Sayfa</div>
        </a>
      </li>
    }

    @if (isAdmin)
    {
      <!-- CRM (Admin) -->
      <li class="menu-header mt-7" id="menu-section-crm">
        <span class="menu-header-text">CRM</span>
      </li>
      <li class='menu-item@(currentPage.StartsWith("/Customers") ? " active" : "")'>
        <a asp-controller="Customers" asp-action="Index" class="menu-link">
          <i class="menu-icon icon-base ri ri-group-line"></i>
          <div>Müşteriler</div>
        </a>
      </li>
      <li class='menu-item@(currentPage.StartsWith("/Suppliers") ? " active" : "")'>
        <a asp-controller="Suppliers" asp-action="Index" class="menu-link">
          <i class="menu-icon icon-base ri ri-building-4-line"></i>
          <div>Tedarikçiler</div>
        </a>
      </li>
    }

    <!-- Siparişler -->
    @if (!isAdmin)
    {
      <li class="menu-header mt-7" id="menu-section-operasyon">
        <span class="menu-header-text">Operasyon</span>
      </li>
    }
    <li class='menu-item@(currentPage.StartsWith("/Orders") ? " active" : "")'>
      <a asp-controller="Orders" asp-action="Index" class="menu-link">
        <i class="menu-icon icon-base ri ri-shopping-bag-3-line"></i>
        <div>Siparişler</div>
      </a>
    </li>

    <li class='menu-item@(currentPage.StartsWith("/Invoices/Sales") || currentPage == "/Invoices/CreateSales" ? " active" : "")'>
      <a asp-controller="Invoices" asp-action="Sales" class="menu-link">
        <i class="menu-icon icon-base ri ri-file-list-3-line"></i>
        <div>Satış Faturaları</div>
      </a>
    </li>

    @if (isAdmin)
    {
      <li class='menu-item@(currentPage.StartsWith("/Invoices/Purchase") || currentPage == "/Invoices/CreatePurchase" ? " active" : "")'>
        <a asp-controller="Invoices" asp-action="Purchase" class="menu-link">
          <i class="menu-icon icon-base ri ri-file-add-line"></i>
          <div>Alış Faturaları</div>
        </a>
      </li>
      <li class='menu-item@(currentPage.StartsWith("/Payments") ? " active" : "")'>
        <a asp-controller="Payments" asp-action="Index" class="menu-link">
          <i class="menu-icon icon-base ri ri-wallet-3-line"></i>
          <div>Kasa & Banka</div>
        </a>
      </li>
    }

    <!-- Stok -->
    <li class="menu-header mt-7" id="menu-section-stok">
      <span class="menu-header-text">Stok</span>
    </li>
    <li class='menu-item@(currentPage.StartsWith("/Stocks") ? " active" : "")'>
      <a asp-controller="Stocks" asp-action="Index" class="menu-link">
        <i class="menu-icon icon-base ri ri-archive-2-line"></i>
        <div>Ürünler</div>
      </a>
    </li>
    <li class='menu-item@(currentPage.StartsWith("/Categories") ? " active" : "")'>
      <a asp-controller="Categories" asp-action="Index" class="menu-link">
        <i class="menu-icon icon-base ri ri-folder-3-line"></i>
        <div>Kategoriler</div>
      </a>
    </li>
    <li class='menu-item@(currentPage.StartsWith("/StockMovements") ? " active" : "")'>
      <a asp-controller="StockMovements" asp-action="Index" class="menu-link">
        <i class="menu-icon icon-base ri ri-exchange-line"></i>
        <div>Stok Hareketleri</div>
      </a>
    </li>

    @if (isAdmin)
    {
      <!-- Raporlar & Yönetim -->
      <li class="menu-header mt-7" id="menu-section-raporlar">
        <span class="menu-header-text">Raporlar & Yönetim</span>
      </li>
      <li class='menu-item@(currentPage.StartsWith("/Reports") ? " active open" : "")'>
        <a href="javascript:void(0);" class="menu-link menu-toggle">
          <i class="menu-icon icon-base ri ri-bar-chart-box-line"></i>
          <div>Raporlar</div>
        </a>
        <ul class="menu-sub">
          <li class='menu-item@(currentPage == "/Reports/SalesReport" ? " active" : "")'>
            <a asp-controller="Reports" asp-action="SalesReport" class="menu-link">
              <div>Satış Raporu</div>
            </a>
          </li>
          <li class='menu-item@(currentPage == "/Reports/StockReport" ? " active" : "")'>
            <a asp-controller="Reports" asp-action="StockReport" class="menu-link">
              <div>Stok Durum Raporu</div>
            </a>
          </li>
        </ul>
      </li>

      <li class='menu-item@(currentPage.StartsWith("/Users") ? " active" : "")'>
        <a asp-controller="Users" asp-action="Index" class="menu-link">
          <i class="menu-icon icon-base ri ri-user-settings-line"></i>
          <div>Personel Yönetimi</div>
        </a>
      </li>
    }

  </ul>

</aside>
<!-- / Menu -->
