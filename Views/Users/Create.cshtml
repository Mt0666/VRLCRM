@model VRLCRM.Models.Auth.UserFormViewModel
@{
    ViewData["Title"] = "Yeni Personel Ekle";
}

<div class="row">
    <div class="col-xl">
        <div class="card mb-6">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Yeni Personel Bilgileri</h5>
                <small class="text-body float-end">Personel Kaydı</small>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="form-floating form-floating-outline mb-5">
                        <input asp-for="FullName" class="form-control" placeholder="Ad Soyad" />
                        <label asp-for="FullName">Ad Soyad</label>
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="form-floating form-floating-outline mb-5">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="05XX XXX XX XX" type="tel" />
                        <label asp-for="PhoneNumber">Telefon Numarası</label>
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="form-floating form-floating-outline mb-5">
                        <input asp-for="Password" class="form-control" placeholder="Şifre" />
                        <label asp-for="Password">Şifre</label>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-floating form-floating-outline mb-5">
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Şifre Onayı" />
                        <label asp-for="ConfirmPassword">Şifre Onayı</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="form-floating form-floating-outline mb-5">
                        <select asp-for="SelectedRole" class="form-select select2">
                            <option value="Personel">Personel</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <label asp-for="SelectedRole">Rol</label>
                        <span asp-validation-for="SelectedRole" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Kaydet</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>
