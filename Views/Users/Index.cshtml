@model IEnumerable<VRLCRM.Controllers.UserViewModel>
@{
    ViewData["Title"] = "Personel Listesi";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Personel Listesi</h5>
        <div class="d-flex gap-2 align-items-center">
          <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
            <i class="ri-question-line"></i>
          </button>
          <a asp-action="Create" class="btn btn-primary">Yeni Personel Ekle</a>
        </div>
    </div>
    <div class="card-body pb-0">
        <partial name="_TableToolbar" />
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover js-data-table">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>Telefon</th>
                    <th>Rol</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @foreach (var user in Model)
                {
                    <tr>
                        <td><strong>@user.FullName</strong></td>
                        <td>@user.PhoneNumber</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-label-primary me-1">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-label-success me-1">Personel</span>
                            }
                        </td>
                        <td>
                            <form asp-action="Delete" asp-route-id="@user.Id" method="post"
                                  onsubmit="return confirm('Bu personeli silmek istediğinize emin misiniz?');">
                                <button type="submit" class="btn btn-sm btn-icon btn-outline-danger" title="Sil">
                                    <i class="ri ri-delete-bin-6-line"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section PageScripts {
<script>
(function () {
  const d = window.driver && window.driver.js && window.driver.js.driver;
  if (!d) return;
  const tour = d({
    animate: true, smoothScroll: true, allowClose: true,
    overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
    nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
    showProgress: true, progressText: '{{current}} / {{total}}',
    steps: [
      { element: '.js-data-table', popover: { title: 'Personel Listesi', description: 'Sisteme giriş yapabilecek kullanıcılar burada yönetilir. Admin rolü tüm modüllere, User rolü sadece operasyonel sayfaLara erişebilir.', side: 'top' } },
      { element: 'a[href*="Create"]', popover: { title: 'Yeni Personel Ekle', description: 'Yeni kullanıcı oluşturun. E-posta, şifre ve rol (Admin/User) belirleyin.', side: 'left' } },
      { element: '.btn-outline-danger', popover: { title: 'Kullanıcı Sil', description: 'Çalışan ayrıldığında hesabı silebilirsiniz. Bu işlem geri alınamaz.', side: 'left' } }
    ]
  });
  document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
})();
</script>
}
