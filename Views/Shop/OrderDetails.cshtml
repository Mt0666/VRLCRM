@model Order
@using VRLCRM.Domain.Enums
@{
  Layout = "_ShopLayout";
  ViewData["Title"] = "Sipariş Detayı";
}

<div class="mb-4">
  <a asp-action="Orders" class="text-body-secondary text-decoration-none small">
    <i class="ri-arrow-left-line me-1"></i>Siparişlerime Dön
  </a>
</div>

<div class="card border-0" style="border-radius:14px; overflow:hidden; box-shadow:0 2px 10px rgba(0,0,0,.04);">
  <div class="card-header bg-white border-bottom py-3">
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
      <div>
        <h5 class="mb-1 fw-bold">@Model.OrderNumber</h5>
        <div class="text-body-secondary small">
          @Model.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        </div>
      </div>
      <div class="text-end">
        <partial name="_OrderStatusBadge" model="Model" />
      </div>
    </div>
  </div>

  <div class="card-body p-4">
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
      <div class="alert alert-secondary py-2 px-3 mb-4" style="font-size:.85rem;">
        <i class="ri-sticky-note-line me-1"></i>@Model.Notes
      </div>
    }

    <div class="table-responsive mb-4">
      <table class="table table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Ürün</th>
            <th class="text-center" style="width:90px">Adet</th>
            <th class="text-end" style="width:120px">Birim Fiyat</th>
            <th class="text-end" style="width:120px">Toplam</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var line in Model.Lines)
          {
            <tr>
              <td>@line.StockItem.Name</td>
              <td class="text-center">@line.Quantity</td>
              <td class="text-end">@line.UnitPrice.ToString("N2") ₺</td>
              <td class="text-end fw-semibold">@line.LineTotal.ToString("N2") ₺</td>
            </tr>
          }
        </tbody>
      </table>
    </div>

    <div class="d-flex justify-content-end">
      <div class="mv-summary-box" style="min-width:280px; max-width:100%;">
        <div class="mv-summary-body py-3">
          <div class="mv-total-row">
            <span>Ara Toplam</span>
            <span>@Model.SubTotal.ToString("N2") ₺</span>
          </div>
          <div class="mv-total-row">
            <span>Toplam KDV</span>
            <span>@Model.VatTotal.ToString("N2") ₺</span>
          </div>
          <div class="mv-total-grand">
            <span>Genel Toplam</span>
            <span>@Model.TotalAmount.ToString("N2") ₺</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
