@{
  var customer = (Customer)ViewBag.Customer!;
  var cartItems = (IReadOnlyList<VRLCRM.Services.CartItem>)ViewBag.CartItems;
  var cartTotal = (decimal)ViewBag.CartTotal;
  ViewData["Title"] = "Sepet";
}

<div class="row">
  <div class="col-xl-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Sepet — @customer.FullName</h5>
        <a asp-action="Index" asp-route-customerId="@customer.Id" class="btn btn-sm btn-outline-secondary">Alışverişe Dön</a>
      </div>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Ürün</th>
              <th>Adet</th>
              <th>Birim Fiyat</th>
              <th>Toplam</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            @if (!cartItems.Any())
            {
              <tr><td colspan="5" class="text-center py-5 text-body-secondary">Sepetiniz boş.</td></tr>
            }
            else
            {
              @foreach (var item in cartItems)
              {
                <tr>
                  <td>@item.Name</td>
                  <td>
                    <form asp-action="UpdateCart" method="post" class="d-flex gap-2">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="customerId" value="@customer.Id" />
                      <input type="hidden" name="stockItemId" value="@item.StockItemId" />
                      <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control form-control-sm" style="width: 80px;" />
                      <button type="submit" class="btn btn-sm btn-outline-primary">Güncelle</button>
                    </form>
                  </td>
                  <td>@item.UnitPrice.ToString("N2") ₺</td>
                  <td>@item.LineTotal.ToString("N2") ₺</td>
                  <td>
                    <form asp-action="RemoveFromCart" method="post">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="customerId" value="@customer.Id" />
                      <input type="hidden" name="stockItemId" value="@item.StockItemId" />
                      <button type="submit" class="btn btn-sm btn-outline-danger">Kaldır</button>
                    </form>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
      @if (cartItems.Any())
      {
        <div class="card-body border-top">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <strong>Genel Toplam</strong>
            <strong>@cartTotal.ToString("N2") ₺</strong>
          </div>
          @{
            var canOrder = customer.CanPlaceOrder(cartTotal);
          }
          @if (!canOrder)
          {
            <div class="alert alert-warning">Cari limit yetersiz. Borç: @customer.Balance.ToString("N2") ₺, Sepet: @cartTotal.ToString("N2") ₺</div>
          }
          <form asp-action="Checkout" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="customerId" value="@customer.Id" />
            <div class="form-floating form-floating-outline mb-4">
              <input type="text" name="notes" class="form-control" placeholder="Sipariş notu" />
              <label>Sipariş Notu</label>
            </div>
            <button type="submit" class="btn btn-success" @(canOrder ? "" : "disabled")>Siparişi Onayla</button>
          </form>
        </div>
      }
    </div>
  </div>
</div>
