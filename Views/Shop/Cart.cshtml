@{
  Layout = "_ShopLayout";
  var customer = (VRLCRM.Domain.Entities.Customer)ViewBag.Customer!;
  var cartItems = (IReadOnlyList<VRLCRM.Services.CartItem>)ViewBag.CartItems;
  var cartTotal = (decimal)ViewBag.CartTotal;
  ViewData["Title"] = "Sepet";
}

<div class="mb-4">
  <a asp-action="Index" class="text-body-secondary text-decoration-none small">
    <i class="ri-arrow-left-line me-1"></i>Alışverişe Devam Et
  </a>
</div>

@if (!cartItems.Any())
{
  <div class="row justify-content-center">
    <div class="col-md-6 text-center py-6">
      <i class="ri-shopping-cart-line d-block mb-3" style="font-size:4rem; color:#c8cadc;"></i>
      <h5 class="fw-semibold mb-2">Sepetiniz boş</h5>
      <p class="text-body-secondary mb-4">Ürün kataloğuna dönerek sipariş oluşturabilirsiniz.</p>
      <a asp-action="Index" class="btn btn-primary px-4">
        <i class="ri-store-2-line me-2"></i>Kataloğa Git
      </a>
    </div>
  </div>
}
else
{
  <div class="row g-4">
    @* ── Cart items ─────────────────────────────────────────────── *@
    <div class="col-lg-8">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="fw-bold mb-0">
          <i class="ri-shopping-cart-line me-1 text-primary"></i>Sepetim
          <span class="badge bg-label-primary ms-1">@cartItems.Count ürün</span>
        </h6>
      </div>

      <div class="d-flex flex-column gap-3">
        @foreach (var item in cartItems)
        {
          <div class="mv-cart-row d-flex flex-wrap align-items-center gap-3">
            @* Icon *@
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3 bg-label-primary"
                 style="width:52px; height:52px;">
              <i class="ri-box-3-line" style="font-size:1.4rem; color:#696cff;"></i>
            </div>

            @* Name + code *@
            <div class="flex-grow-1" style="min-width:120px;">
              <div class="fw-semibold" style="font-size:.92rem;">@item.Name</div>
              <div class="text-body-secondary" style="font-size:.77rem;">
                Birim: <strong>@item.UnitPrice.ToString("N2") ₺</strong>
              </div>
              <form asp-action="UpdateCartNotes" method="post" class="mt-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="stockItemId" value="@item.StockItemId" />
                <label class="form-label small text-body-secondary mb-1">Ürün açıklaması</label>
                <textarea name="notes" class="form-control form-control-sm" rows="2"
                          placeholder="Bu ürün için not yazın…"
                          style="border-radius:8px; font-size:.8rem; resize:none;">@item.Notes</textarea>
                <button type="submit" class="btn btn-sm btn-outline-secondary mt-1">Açıklamayı Kaydet</button>
              </form>
            </div>

            @* Qty form *@
            <form asp-action="UpdateCart" method="post" class="d-flex align-items-center gap-2 flex-shrink-0">
              @Html.AntiForgeryToken()
              <input type="hidden" name="stockItemId" value="@item.StockItemId" />
              <input type="number" name="quantity" value="@item.Quantity" min="0"
                     class="form-control form-control-sm text-center fw-semibold mv-qty-input"
                     style="border-radius:8px;" />
              <button type="submit" class="btn btn-sm btn-outline-primary px-2" title="Güncelle" style="border-radius:8px;">
                <i class="ri-refresh-line"></i>
              </button>
            </form>

            @* Line total *@
            <div class="fw-bold text-primary text-end flex-shrink-0" style="min-width:90px; font-size:.95rem;">
              @item.LineTotal.ToString("N2") ₺
            </div>

            @* Remove *@
            <form asp-action="RemoveFromCart" method="post" class="flex-shrink-0">
              @Html.AntiForgeryToken()
              <input type="hidden" name="stockItemId" value="@item.StockItemId" />
              <button type="submit" class="btn btn-sm btn-outline-danger px-2" title="Kaldır" style="border-radius:8px;">
                <i class="ri-delete-bin-line"></i>
              </button>
            </form>
          </div>
        }
      </div>
    </div>

    @* ── Order summary ───────────────────────────────────────────── *@
    <div class="col-lg-4">
      <div class="mv-summary-box">
        <div class="mv-summary-head">
          <i class="ri-file-list-3-line me-2"></i>Sipariş Özeti
        </div>
        <div class="mv-summary-body">
          @foreach (var item in cartItems)
          {
            <div class="mv-total-row">
              <span class="text-truncate pe-2" style="max-width:160px;">@item.Name <span class="text-body-secondary">×@item.Quantity</span></span>
              <span class="flex-shrink-0">@item.LineTotal.ToString("N2") ₺</span>
            </div>
          }

          <div class="mv-total-grand mt-2">
            <span>Genel Toplam</span>
            <span>@cartTotal.ToString("N2") ₺</span>
          </div>
        </div>
      </div>

      @* Checkout form *@
      <form asp-action="Checkout" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:.85rem;">
            Sipariş Notu <span class="text-body-secondary fw-normal">(isteğe bağlı)</span>
          </label>
          <textarea name="notes" class="form-control" rows="3"
                    placeholder="Özel isteklerinizi yazabilirsiniz…"
                    style="border-radius:10px; font-size:.85rem; resize:none;"></textarea>
        </div>
        <button type="submit" class="btn btn-success w-100 py-2" style="border-radius:10px; font-size:.9rem; font-weight:600;">
          <i class="ri-checkbox-circle-line me-2"></i>Siparişi Onayla
        </button>
      </form>
    </div>
  </div>
}
