@model IReadOnlyList<StockItem>
@{
  var customer = (Customer)ViewBag.Customer!;
  var cartItems = (IReadOnlyList<VRLCRM.Services.CartItem>)ViewBag.CartItems;
  var cartTotal = (decimal)ViewBag.CartTotal;
  ViewData["Title"] = $"{customer.FullName} - Mağaza";
}

<div class="row g-6">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h5 class="mb-1">Ürünler</h5>
          <small class="text-body-secondary">@customer.FullName</small>
        </div>
        <div class="d-flex gap-2">
          <a asp-controller="Customers" asp-action="Details" asp-route-id="@customer.Id" class="btn btn-outline-secondary btn-sm">Müşteri</a>
          <a asp-action="Cart" asp-route-customerId="@customer.Id" class="btn btn-primary btn-sm">
            Sepet (@cartItems.Count) — @cartTotal.ToString("N2") ₺
          </a>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-4">
          @foreach (var stock in Model)
          {
            var inStock = stock.StockQuantity > 0;
            <div class="col-md-6 col-xl-4">
              <div class="card h-100 border">
                @if (!string.IsNullOrWhiteSpace(stock.ImageUrl))
                {
                  <img src="@stock.ImageUrl" class="card-img-top" alt="@stock.Name" style="height: 160px; object-fit: cover;" />
                }
                <div class="card-body d-flex flex-column">
                  <h6 class="card-title">@stock.Name</h6>
                  <p class="text-body-secondary small mb-2">@stock.StockCode</p>
                  <p class="fw-semibold mb-2">@stock.Price.ToString("N2") ₺</p>
                  @if (inStock)
                  {
                    <span class="badge bg-label-success align-self-start mb-3">Stokta (@stock.StockQuantity)</span>
                  }
                  else
                  {
                    <span class="badge bg-label-danger align-self-start mb-3">Stokta yok</span>
                  }
                  @if (inStock && customer.IsActive)
                  {
                    <form asp-action="AddToCart" method="post" class="mt-auto d-flex gap-2">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="customerId" value="@customer.Id" />
                      <input type="hidden" name="stockItemId" value="@stock.Id" />
                      <input type="number" name="quantity" value="1" min="1" max="@stock.StockQuantity" class="form-control form-control-sm" style="width: 70px;" />
                      <button type="submit" class="btn btn-sm btn-primary flex-grow-1">Sepete Ekle</button>
                    </form>
                  }
                </div>
              </div>
            </div>
          }
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header"><h6 class="mb-0">Cari Özet</h6></div>
      <div class="card-body">
        <p class="mb-2"><strong>Borç:</strong> @customer.Balance.ToString("N2") ₺</p>
        <p class="mb-2"><strong>Limit:</strong> @(customer.CreditLimit.HasValue ? $"{customer.CreditLimit:N2} ₺" : "Limitsiz")</p>
        @if (customer.CreditLimit.HasValue)
        {
          <p class="mb-0"><strong>Kullanılabilir:</strong> @customer.AvailableCredit?.ToString("N2") ₺</p>
        }
      </div>
    </div>
  </div>
</div>
