@model VRLCRM.Models.Auth.LoginViewModel
@{
  Layout = "_BlankLayout";
  ViewData["Title"] = "Giriş Yap";
}

@section PageStyles {
<link rel="stylesheet" href="~/vendor/css/pages/page-auth.css" />
}

@* ************** Content ************** *@
<div class="position-relative">
  <div class="authentication-wrapper authentication-basic container-p-y">
    <div class="authentication-inner py-6 mx-4">
      <!-- Login -->
      <div class="card p-sm-7 p-2">
        <!-- Logo -->
        <div class="app-brand justify-content-center mt-5">
          <a href="/" class="app-brand-link gap-3">
            <span class="app-brand-logo demo">@await Html.PartialAsync("../_Partials/_Macros")</span>
            <span class="app-brand-text demo text-heading fw-semibold">VRLCRM</span>
          </a>
        </div>
        <!-- /Logo -->

        <div class="card-body mt-1">
          <h4 class="mb-1">VRLCRM'e Hoş Geldiniz! 👋🏻</h4>
          <p class="mb-5">Lütfen hesabınızla giriş yapın.</p>

          <form asp-action="LoginBasic" asp-controller="Auth" method="POST" class="mb-5">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="ReturnUrl" />
            
            <div class="form-floating form-floating-outline mb-5">
              <input asp-for="Email" class="form-control" placeholder="Email adresinizi giriniz" autofocus />
              <label asp-for="Email">Email</label>
              <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            
            <div class="mb-5">
              <div class="form-password-toggle">
                <div class="input-group input-group-merge">
                  <div class="form-floating form-floating-outline">
                    <input asp-for="Password" class="form-control" placeholder="&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;&#xb7;" />
                    <label asp-for="Password">Şifre</label>
                  </div>
                  <span class="input-group-text cursor-pointer"><i class="icon-base ri ri-eye-off-line icon-20px"></i></span>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
              </div>
            </div>
            
            <div class="mb-5 pb-2 d-flex justify-content-between pt-2 align-items-center">
              <div class="form-check mb-0">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"> Beni Hatırla </label>
              </div>
              <a href="/Auth/ForgotPasswordBasic" class="float-end mb-1">
                <span>Şifremi Unuttum?</span>
              </a>
            </div>
            
            <div class="mb-5">
              <button class="btn btn-primary d-grid w-100" type="submit">Giriş Yap</button>
            </div>
          </form>
        </div>
      </div>
      <!-- /Login -->
      <img src="~/img/illustrations/tree-3.png" alt="auth-tree" class="authentication-image-object-left d-none d-lg-block" />
      <img src="~/img/illustrations/auth-basic-mask-light.png" class="authentication-image d-none d-lg-block scaleX-n1-rtl" height="172" alt="triangle-bg" data-app-light-img="illustrations/auth-basic-mask-light.png" data-app-dark-img="illustrations/auth-basic-mask-dark.png" />
      <img src="~/img/illustrations/tree.png" alt="auth-tree" class="authentication-image-object-right d-none d-lg-block" />
    </div>
  </div>
</div>
