@model IReadOnlyList<VRLCRM.Domain.Entities.Invoice>

<div class="card-toolbar d-flex flex-wrap justify-content-between align-items-center gap-3 px-4 pt-4 pb-2">
  <div class="d-flex align-items-center gap-2">
    <input type="text" class="form-control form-control-sm js-table-search" placeholder="Ara..." style="width:200px" />
  </div>
  <div class="d-flex align-items-center gap-2">
    <label class="text-body-secondary small mb-0">Göster:</label>
    <select class="form-select form-select-sm js-table-page-size" style="width:75px">
      <option value="10">10</option>
      <option value="25" selected>25</option>
      <option value="50">50</option>
    </select>
  </div>
</div>

<div class="table-responsive text-nowrap">
  <table class="table table-hover js-data-table mb-0">
    <thead>
      <tr>
        <th>Fatura No</th>
        <th>Tarih</th>
        <th>Tutar</th>
        <th></th>
      </tr>
    </thead>
    <tbody class="table-border-bottom-0">
      @if (!Model.Any())
      {
        <tr>
          <td colspan="4" class="text-center py-5 text-body-secondary">Alış faturası bulunamadı.</td>
        </tr>
      }
      else
      {
        @foreach (var invoice in Model)
        {
          <tr>
            <td>@invoice.InvoiceNumber</td>
            <td>@invoice.InvoiceDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
            <td class="fw-semibold">@invoice.TotalAmount.ToString("N2") ₺</td>
            <td>
              <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id"
                 class="btn btn-sm btn-outline-primary">
                <i class="ri-eye-line me-1"></i>Detay
              </a>
            </td>
          </tr>
        }
      }
    </tbody>
  </table>
</div>
