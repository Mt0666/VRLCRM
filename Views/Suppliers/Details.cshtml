@model Supplier
@{ ViewData["Title"] = "Tedarikçi Detayı"; }

<div class="row g-6">

  @* Sol: Tedarikçi bilgileri *@
  <div class="col-xl-4 col-lg-5">

    @* Profil kartı *@
    <div class="card mb-6">
      <div class="card-body pt-5 pb-4 text-center">
        <div class="avatar avatar-xl mx-auto mb-3">
          <span class="avatar-initial rounded-circle bg-label-warning" style="font-size:1.5rem;">
            @(string.IsNullOrWhiteSpace(Model.CompanyName) ? "?" : Model.CompanyName[0].ToString().ToUpperInvariant())
          </span>
        </div>
        <h5 class="mb-1">@Model.CompanyName</h5>
        @if (!string.IsNullOrWhiteSpace(Model.ContactName))
        {
          <p class="text-body-secondary mb-2 small">@Model.ContactName</p>
        }
        <partial name="_StatusBadge" model="Model.IsActive" />
      </div>
      <div class="card-footer d-flex justify-content-center gap-2 flex-wrap py-3">
        @if (!Model.IsActive)
        {
          <form asp-action="Restore" asp-route-id="@Model.Id" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm">
              <i class="ri-refresh-line me-1"></i>Aktif Yap
            </button>
          </form>
        }
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
          <i class="ri-pencil-line me-1"></i>Düzenle
        </a>
        @if (Model.IsActive)
        {
          <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">
            <i class="ri-delete-bin-6-line me-1"></i>Pasife Al
          </a>
        }
        <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
          <i class="ri-question-line"></i>
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
      </div>
    </div>

    @* Cari bilgiler *@
    <div class="card mb-6">
      <div class="card-header">
        <h6 class="mb-0">Cari Bilgiler</h6>
      </div>
      <div class="detail-info-strip" style="border-radius:0; border-left:0; border-right:0; border-bottom:0; margin-bottom:0;">
        <div class="detail-info-item">
          <div class="detail-info-label">Telefon</div>
          <div class="detail-info-value">@(Model.PhoneNumber ?? "-")</div>
        </div>
        <div class="detail-info-item">
          <div class="detail-info-label">Vergi No</div>
          <div class="detail-info-value">@(Model.TaxNumber ?? "-")</div>
        </div>
        <div class="detail-info-item">
          <div class="detail-info-label">Cari Borç</div>
          <div class="detail-info-value @(Model.Balance > 0 ? "text-danger" : "")">@Model.Balance.ToString("N2") ₺</div>
        </div>
        <div class="detail-info-item">
          <div class="detail-info-label">Cari Limit</div>
          <div class="detail-info-value">@(Model.CreditLimit.HasValue ? $"{Model.CreditLimit:N2} ₺" : "Limitsiz")</div>
        </div>
        @if (Model.CreditLimit.HasValue)
        {
          <div class="detail-info-item">
            <div class="detail-info-label">Kullanılabilir</div>
            <div class="detail-info-value @(Model.AvailableCredit < 0 ? "text-danger" : "")">@Model.AvailableCredit?.ToString("N2") ₺</div>
          </div>
        }
      </div>
    </div>

    @* Adres *@
    @if (!string.IsNullOrWhiteSpace(Model.City) || !string.IsNullOrWhiteSpace(Model.AddressLine))
    {
      <div class="card mb-6">
        <div class="card-header">
          <h6 class="mb-0">Adres</h6>
        </div>
        <div class="card-body small">
          <p class="mb-1"><i class="ri-map-pin-line me-1 text-body-secondary"></i>@(Model.City ?? "-") / @(Model.District ?? "-")</p>
          @if (!string.IsNullOrWhiteSpace(Model.AddressLine))
          {
            <p class="mb-0 text-body-secondary">@Model.AddressLine</p>
          }
        </div>
      </div>
    }

    @* Notlar *@
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
      <div class="card">
        <div class="card-header">
          <h6 class="mb-0">Notlar</h6>
        </div>
        <div class="card-body small text-body-secondary">
          @Model.Notes
        </div>
      </div>
    }

  </div>

  @* Sağ: Alış Faturaları + Ödemeler *@
  <div class="col-xl-8 col-lg-7">

    <div class="card mb-6">
      <div class="card-header">
        <h6 class="mb-0"><i class="ri-file-list-3-line me-2 text-warning"></i>Alış Faturaları</h6>
      </div>
      <div id="invoices-container">
        <div class="d-flex justify-content-center align-items-center py-5">
          <div class="spinner-border spinner-border-sm text-warning me-2"></div>
          <span class="text-body-secondary small">Yükleniyor…</span>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h6 class="mb-0"><i class="ri-money-dollar-circle-line me-2 text-success"></i>Ödeme Hareketleri</h6>
      </div>
      <div id="payments-container">
        <div class="d-flex justify-content-center align-items-center py-5">
          <div class="spinner-border spinner-border-sm text-success me-2"></div>
          <span class="text-body-secondary small">Yükleniyor…</span>
        </div>
      </div>
    </div>

  </div>

</div>

@section PageScripts {
  <script>
    (function () {
      const supplierId = @Model.Id;

      function loadPartial(url, containerId) {
        fetch(url)
          .then(function(r) { return r.ok ? r.text() : Promise.reject(r.status); })
          .then(function(html) {
            var container = document.getElementById(containerId);
            container.innerHTML = html;
            container.querySelectorAll('table.js-data-table').forEach(function(table) {
              if (window._initTableFilter) window._initTableFilter(table);
            });
          })
          .catch(function() {
            document.getElementById(containerId).innerHTML =
              '<p class="text-danger text-center py-4 small">Yüklenemedi.</p>';
          });
      }

      loadPartial('/Suppliers/InvoicesPartial/' + supplierId, 'invoices-container');
      loadPartial('/Suppliers/PaymentsPartial/' + supplierId, 'payments-container');
    })();
  </script>
  <script>
  (function () {
    const d = window.driver && window.driver.js && window.driver.js.driver;
    if (!d) return;
    const tour = d({
      animate: true, smoothScroll: true, allowClose: true,
      overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
      nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
      showProgress: true, progressText: '{{current}} / {{total}}',
      steps: [
        { element: '.avatar-initial', popover: { title: 'Tedarikçi Profili', description: 'Tedarikçi firma adı, yetkili kişi ve durum bilgisi.', side: 'bottom' } },
        { element: 'a[href*="Edit"]', popover: { title: 'Düzenle', description: 'Tedarikçi bilgilerini güncellemek için tıklayın.', side: 'right' } },
        { element: '.detail-info-strip', popover: { title: 'Cari Bilgiler', description: 'Tedarikçiye olan borcunuz (cari hesap), vergi numarası ve limit bilgileri. Borç alış faturasında artar, ödeme yapınca düşer.', side: 'right' } },
        { element: '#invoices-container', popover: { title: 'Alış Fatura Geçmişi', description: 'Bu tedarikçiden alınan tüm alış faturaları. Fatura numarasına tıklayarak detaya gidebilirsiniz.', side: 'top' } },
        { element: '#payments-container', popover: { title: 'Ödeme Geçmişi', description: 'Tedarikçiden alınan tahsilatlar ve tedarikçiye yapılan ödemeler burada listelenir. PDF olarak dışa aktarabilirsiniz.', side: 'top' } }
      ]
    });
    document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
  })();
  </script>
}
