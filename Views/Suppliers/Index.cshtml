@model IReadOnlyList<Supplier>
@{
  ViewData["Title"] = "Tedarikçiler";
}

<div class="card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
    <h5 class="mb-0">Tedarikçi Listesi</h5>
    <div class="d-flex gap-2 align-items-center">
      <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
        <i class="ri-question-line"></i>
      </button>
      <a asp-action="Create" class="btn btn-primary btn-sm">Yeni Tedarikçi</a>
    </div>
  </div>
  <div class="card-body pb-0">
    <partial name="_TableToolbar" />
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover js-data-table">
      <thead>
        <tr>
          <th>Firma</th>
          <th>Yetkili</th>
          <th>Telefon</th>
          <th>Cari Borç</th>
          <th>Durum</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        @if (!Model.Any())
        {
          <tr><td colspan="6" class="text-center py-5 text-body-secondary">Henüz tedarikçi kaydı yok.</td></tr>
        }
        else
        {
          @foreach (var supplier in Model)
          {
            <tr class="@(supplier.IsActive ? "" : "table-secondary")">
              <td><strong>@supplier.CompanyName</strong></td>
              <td>@(supplier.ContactName ?? "-")</td>
              <td>@supplier.PhoneNumber</td>
              <td>@supplier.Balance.ToString("N2") ₺</td>
              <td><partial name="_StatusBadge" model="supplier.IsActive" /></td>
              <td>
                <a asp-action="Details" asp-route-id="@supplier.Id"
                   class="btn btn-sm btn-outline-primary">
                  <i class="ri ri-eye-line me-1"></i>Detay
                </a>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

@section PageScripts {
<script>
(function () {
  const d = window.driver && window.driver.js && window.driver.js.driver;
  if (!d) return;
  const tour = d({
    animate: true, smoothScroll: true, allowClose: true,
    overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
    nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
    showProgress: true, progressText: '{{current}} / {{total}}',
    steps: [
      {
        element: '.js-data-table',
        popover: {
          title: 'Tedarikçi Listesi',
          description: 'Ürün aldığınız tedarikçiler burada listelenir. Cari hesap bakiyesi ve kredi limiti takibi yapabilirsiniz.',
          side: 'top'
        }
      },
      {
        element: '.js-search-input',
        popover: {
          title: 'Hızlı Arama',
          description: 'Tedarikçi adı veya vergi numarasıyla anında filtrele.',
          side: 'bottom'
        }
      },
      {
        element: 'th:nth-child(3)',
        popover: {
          title: 'Cari Borç',
          description: 'Tedarikçiye olan borcunuz. Alış faturasında artar, ödeme yapınca düşer.',
          side: 'bottom'
        }
      },
      {
        element: 'a[href*="Create"]',
        popover: {
          title: 'Yeni Tedarikçi',
          description: 'Tedarikçi kaydı oluşturun. Vergi no, iletişim bilgileri ve cari limit girebilirsiniz.',
          side: 'left'
        }
      }
    ]
  });
  document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
})();
</script>
}
