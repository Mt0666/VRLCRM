@model IEnumerable<VRLCRM.Domain.Entities.Invoice>
@{
  ViewData["Title"] = "Satış Raporu";

  var totalAmount  = Model.Sum(i => i.TotalAmount);
  var invoiceCount = Model.Count();
  var avgAmount    = invoiceCount > 0 ? totalAmount / invoiceCount : 0m;
  var maxAmount    = invoiceCount > 0 ? Model.Max(i => i.TotalAmount) : 0m;

  var dailySales = Model
    .GroupBy(i => i.InvoiceDate.Date)
    .OrderBy(g => g.Key)
    .Select(g => new { date = g.Key.ToString("dd.MM"), total = g.Sum(i => i.TotalAmount) })
    .ToList();

  var topCustomers = Model
    .Where(i => i.Customer != null)
    .GroupBy(i => i.Customer!.FullName)
    .Select(g => new { name = g.Key, total = g.Sum(i => i.TotalAmount) })
    .OrderByDescending(x => x.total)
    .Take(5)
    .ToList();

  var othersTotal = Model
    .Where(i => i.Customer != null)
    .GroupBy(i => i.Customer!.FullName)
    .Select(g => g.Sum(i => i.TotalAmount))
    .OrderByDescending(x => x)
    .Skip(5)
    .Sum();

  var fmt = (decimal v) => v.ToString("N2") + " ₺";
}

<div class="card">
  <div class="card-header">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
      <div>
        <h5 class="mb-0">Satış Raporu</h5>
        <small class="text-body-secondary">@ViewBag.StartDate — @ViewBag.EndDate</small>
      </div>
      <div class="d-flex flex-wrap gap-2 align-items-center">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
          <input type="date" class="form-control form-control-sm" name="startDate" value="@ViewBag.StartDate" />
          <span class="text-body-secondary">—</span>
          <input type="date" class="form-control form-control-sm" name="endDate" value="@ViewBag.EndDate" />
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="ri-filter-line me-1"></i>Filtrele
          </button>
        </form>
        <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
          <i class="ri-question-line"></i>
        </button>
      </div>
    </div>
  </div>

  <div class="card-body">

    @* ── Özet şeridi ─────────────────────────────────────────────── *@
    <div class="detail-info-strip mb-4">
      <div class="detail-info-item">
        <div class="detail-info-label">Toplam Satış</div>
        <div class="detail-info-value">@fmt(totalAmount)</div>
      </div>
      <div class="detail-info-item">
        <div class="detail-info-label">Fatura Sayısı</div>
        <div class="detail-info-value">@invoiceCount adet</div>
      </div>
      <div class="detail-info-item">
        <div class="detail-info-label">Ortalama Fatura</div>
        <div class="detail-info-value">@fmt(avgAmount)</div>
      </div>
      <div class="detail-info-item">
        <div class="detail-info-label">En Yüksek Fatura</div>
        <div class="detail-info-value">@fmt(maxAmount)</div>
      </div>
    </div>

    @if (Model.Any())
    {
      @* ── Grafikler ──────────────────────────────────────────────── *@
      <div class="row g-4 mb-4">
        <div class="col-lg-8">
          <div class="card border h-100">
            <div class="card-header py-2">
              <h6 class="mb-0">Günlük Satış Trendi</h6>
            </div>
            <div class="card-body p-3" style="min-height:260px;">
              <canvas id="salesTrendChart"></canvas>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card border h-100">
            <div class="card-header py-2">
              <h6 class="mb-0">Müşteri Dağılımı</h6>
            </div>
            <div class="card-body p-3 d-flex align-items-center justify-content-center">
              <canvas id="customerChart" style="max-height:240px;"></canvas>
            </div>
          </div>
        </div>
      </div>
    }

    @* ── Fatura tablosu ─────────────────────────────────────────── *@
    <div class="table-responsive mb-0">
      <table class="table table-bordered table-sm align-middle js-lines-table" id="salesTable">
        <thead class="table-light">
          <tr>
            <th>Fatura No</th>
            <th>Tarih</th>
            <th>Müşteri</th>
            <th class="text-end" style="width:140px">Tutar</th>
          </tr>
        </thead>
        <tbody id="salesTableBody">
          @if (!Model.Any())
          {
            <tr id="salesEmptyRow">
              <td colspan="4" class="text-center text-body-secondary py-4">
                <i class="ri-inbox-line me-1"></i>Bu tarih aralığında satış faturası bulunamadı.
              </td>
            </tr>
          }
          else
          {
            @foreach (var invoice in Model)
            {
              <tr>
                <td data-label="Fatura No">
                  <a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id" class="fw-semibold">
                    @invoice.InvoiceNumber
                  </a>
                </td>
                <td data-label="Tarih">@invoice.InvoiceDate.ToString("dd.MM.yyyy")</td>
                <td data-label="Müşteri">@invoice.Customer?.FullName</td>
                <td data-label="Tutar" class="text-end fw-semibold">@invoice.TotalAmount.ToString("N2") ₺</td>
              </tr>
            }
          }
        </tbody>
      </table>
    </div>

    @* ── Pagination bar ─────────────────────────────────────────── *@
    @if (Model.Any())
    {
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mt-3">
        <div class="d-flex align-items-center gap-2">
          <span class="text-body-secondary small" id="salesCounter"></span>
          <select class="form-select form-select-sm" id="salesPageSize" style="width:auto;">
            <option value="10" selected>10 satır</option>
            <option value="25">25 satır</option>
            <option value="50">50 satır</option>
            <option value="99999">Tümü</option>
          </select>
        </div>
        <nav aria-label="Fatura sayfalama">
          <ul class="pagination pagination-sm mb-0" id="salesPagination"></ul>
        </nav>
      </div>
    }

  </div>
</div>

@section PageScripts {
  @if (Model.Any())
  {
    <script src="/vendor/libs/chart.js/chart.umd.min.js"></script>
    <script>
      const PALETTE = ['#696cff','#03c3ec','#71dd37','#ffab00','#ff3e1d','#8592a3','#26c6da','#a389d4'];

      // ── Günlük satış trendi (Line) ──────────────────────────────
      const trendLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailySales.Select(d => d.date)));
      const trendData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailySales.Select(d => d.total)));

      new Chart(document.getElementById('salesTrendChart'), {
        type: 'line',
        data: {
          labels: trendLabels,
          datasets: [{
            label: 'Satış (₺)',
            data: trendData,
            borderColor: '#696cff',
            backgroundColor: 'rgba(105,108,255,0.1)',
            borderWidth: 2.5,
            pointRadius: trendLabels.length > 20 ? 2 : 4,
            pointBackgroundColor: '#696cff',
            fill: true,
            tension: 0.4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: ctx => ' ' + Number(ctx.raw).toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' ₺'
              }
            }
          },
          scales: {
            x: { grid: { display: false }, ticks: { maxRotation: 45, font: { size: 11 } } },
            y: {
              grid: { color: 'rgba(0,0,0,0.05)' },
              ticks: {
                font: { size: 11 },
                callback: v => v.toLocaleString('tr-TR', { maximumFractionDigits: 0 }) + ' ₺'
              }
            }
          }
        }
      });

      // ── Müşteri dağılımı (Doughnut) ────────────────────────────
      const custLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        topCustomers.Select(c => c.name).Concat(othersTotal > 0 ? new[] { "Diğerleri" } : Array.Empty<string>())
      ));
      const custData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        topCustomers.Select(c => c.total).Concat(othersTotal > 0 ? new[] { othersTotal } : Array.Empty<decimal>())
      ));

      new Chart(document.getElementById('customerChart'), {
        type: 'doughnut',
        data: {
          labels: custLabels,
          datasets: [{
            data: custData,
            backgroundColor: PALETTE,
            borderWidth: 2,
            hoverOffset: 6
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12, boxWidth: 12 } },
            tooltip: {
              callbacks: {
                label: ctx => ' ' + Number(ctx.raw).toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' ₺'
              }
            }
          },
          cutout: '60%'
        }
      });

      // ── Pagination ─────────────────────────────────────────────
      (function () {
        const tbody      = document.getElementById('salesTableBody');
        const pagEl      = document.getElementById('salesPagination');
        const counterEl  = document.getElementById('salesCounter');
        const sizeSelect = document.getElementById('salesPageSize');

        const dataRows = () => Array.from(tbody.querySelectorAll('tr:not(#salesEmptyRow)'));
        let page = 1;

        function pageSize() { return parseInt(sizeSelect.value, 10); }

        function render() {
          const rows  = dataRows();
          const total = rows.length;
          const ps    = pageSize();
          const pages = ps >= 99999 ? 1 : Math.ceil(total / ps) || 1;
          page = Math.min(page, pages);

          const start = (page - 1) * ps;
          rows.forEach((r, i) => {
            r.style.display = (ps >= 99999 || (i >= start && i < start + ps)) ? '' : 'none';
          });

          if (total === 0) {
            counterEl.textContent = '';
          } else if (ps >= 99999) {
            counterEl.textContent = total + ' fatura';
          } else {
            counterEl.textContent = (start + 1) + '–' + Math.min(start + ps, total) + ' / ' + total + ' fatura';
          }

          pagEl.innerHTML = '';
          if (pages <= 1) return;

          const addBtn = (html, target, disabled, active) => {
            const li  = document.createElement('li');
            li.className = 'page-item' + (disabled ? ' disabled' : '') + (active ? ' active' : '');
            const btn = document.createElement('button');
            btn.type      = 'button';
            btn.className = 'page-link';
            btn.innerHTML = html;
            if (!disabled && !active) btn.onclick = () => { page = target; render(); };
            li.appendChild(btn);
            pagEl.appendChild(li);
          };

          addBtn('&#8249;', page - 1, page === 1, false);

          const maxV = 5;
          let s = Math.max(1, page - Math.floor(maxV / 2));
          let e = Math.min(pages, s + maxV - 1);
          if (e - s < maxV - 1) s = Math.max(1, e - maxV + 1);

          if (s > 1) { addBtn('1', 1, false, false); if (s > 2) addBtn('&hellip;', 0, true, false); }
          for (let p = s; p <= e; p++) addBtn(String(p), p, false, p === page);
          if (e < pages) { if (e < pages - 1) addBtn('&hellip;', 0, true, false); addBtn(String(pages), pages, false, false); }

          addBtn('&#8250;', page + 1, page === pages, false);
        }

        sizeSelect.addEventListener('change', () => { page = 1; render(); });
        render();
      })();
    </script>
    <script>
    (function () {
      const d = window.driver && window.driver.js && window.driver.js.driver;
      if (!d) return;
      const tour = d({
        animate: true, smoothScroll: true, allowClose: true,
        overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
        nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
        showProgress: true, progressText: '{{current}} / {{total}}',
        steps: [
          { element: 'input[name="startDate"]', popover: { title: 'Tarih Filtresi', description: 'Başlangıç ve bitiş tarihlerini seçip Filtrele\'ye basarak istediğiniz döneme ait satışları görüntüleyin.', side: 'bottom' } },
          { element: '.detail-info-strip', popover: { title: 'Dönem Özeti', description: 'Seçili dönem için toplam satış, fatura sayısı, ortalama ve maksimum fatura tutarını bir bakışta görün.', side: 'bottom' } },
          { element: '#salesTrendChart', popover: { title: 'Günlük Satış Trendi', description: 'Dönem içindeki günlük satış seyrini gösterir. Yoğun günleri ve düşüş dönemlerini kolayca tespit edebilirsiniz.', side: 'top' } },
          { element: '#customerChart', popover: { title: 'Müşteri Dağılımı', description: 'Satışların hangi müşterilerden geldiğini gösterir. "Diğerleri" dilimi geri kalan müşterileri temsil eder.', side: 'top' } },
          { element: '#salesTable', popover: { title: 'Fatura Listesi', description: 'Dönemdeki tüm satış faturaları. Fatura numarasına tıklayarak detaya gidebilirsiniz.', side: 'top' } },
          { element: '#salesPageSize', popover: { title: 'Sayfa Boyutu', description: 'Listede kaç satır görüneceğini seçin. "Tümü" seçeneği tüm faturaları tek sayfada gösterir.', side: 'top' } }
        ]
      });
      document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
    })();
    </script>
  }
}
