@model InvoiceFormViewModel
@{
  ViewData["Title"] = "Alış Faturası";
}

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Yeni Alış Faturası</h5>
        <div class="d-flex gap-2 align-items-center">
          <button type="button" id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
            <i class="ri-question-line"></i>
          </button>
          <a asp-action="Purchase" class="btn btn-sm btn-outline-secondary">Listeye Dön</a>
        </div>
      </div>
      <div class="card-body">
        <form asp-action="CreatePurchase" method="post" id="purchaseForm">
          <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

          @* Tedarikçi + Tarih *@
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label asp-for="SupplierId" class="form-label"></label>
              <select asp-for="SupplierId" asp-items="Model.Suppliers" class="form-select select2">
                <option value="">Tedarikçi seçin</option>
              </select>
              <div id="supplierError" class="text-danger small d-none">Bu alan doldurulmalıdır.</div>
              <span asp-validation-for="SupplierId" class="text-danger small"></span>
              @if (!Model.Suppliers.Any())
              {
                <div class="form-text">Henüz tedarikçi yok. <a asp-controller="Suppliers" asp-action="Create">Tedarikçi oluştur</a></div>
              }
            </div>
            <div class="col-md-6">
              <label asp-for="InvoiceDate" class="form-label"></label>
              <input asp-for="InvoiceDate" class="form-control" type="date" />
              <span asp-validation-for="InvoiceDate" class="text-danger small"></span>
            </div>
          </div>

          @* Notlar *@
          <div class="mb-4">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
          </div>

          @* Excel ile toplu giriş *@
          <div class="card border border-success mb-4">
            <div class="card-body">
              <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                  <h6 class="mb-1 fw-semibold">
                    <i class="ri-file-excel-2-line me-1 text-success"></i>Excel ile Toplu Giriş
                  </h6>
                  <p class="text-body-secondary small mb-0">
                    Tüm alış kalemlerini Excel şablonu ile toplu ekleyin.
                    Stokta olmayan ürünler tabloda <span class="badge bg-label-info">Yeni</span> olarak görünür.
                    Kategori listede yoksa Excel yüklenirken otomatik oluşturulur, ardından ürünler tabloya eklenir.
                  </p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                  <a asp-action="DownloadPurchaseImportTemplate" class="btn btn-success">
                    <i class="ri-file-download-line me-1"></i>Şablon İndir
                  </a>
                  <button type="button" id="importExcelBtn" class="btn btn-outline-success">
                    <i class="ri-file-upload-line me-1"></i>Excel Yükle
                  </button>
                  <input type="file" id="excelImportInput" accept=".xlsx,.xls" class="d-none" />
                </div>
              </div>
              <div id="excelImportMessage" class="alert alert-info py-2 px-3 small d-none mt-3 mb-0" role="alert"></div>
            </div>
          </div>

          @* Ürün Ekleme Paneli *@
          <div class="card border mb-4">
            <div class="card-header py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
              <span class="fw-semibold small text-body"><i class="ri-add-circle-line me-1"></i>Tek Tek Ürün Ekle</span>
              <div class="d-flex gap-2 flex-wrap">
                <button type="button" id="openNewProductBtn" class="btn btn-sm btn-outline-primary">
                  <i class="ri-add-box-line me-1"></i>Stokta Tanımsız Ürün
                </button>
                <button type="button" id="scannerBtn" class="btn btn-sm btn-outline-info">
                  <i class="ri-camera-line me-1"></i>Barkod Tara
                </button>
              </div>
            </div>
            <div class="card-body">
              @* Kamera okuyucu alanı *@
              <div id="scannerWrapper" class="mb-3" style="display:none;">
                <div id="qr-reader" style="width:100%; max-width:500px; margin:0 auto; border-radius:0.375rem; overflow:hidden;"></div>
                <div class="d-flex justify-content-center mt-2">
                  <button type="button" id="stopScannerBtn" class="btn btn-sm btn-outline-secondary">
                    <i class="ri-camera-off-line me-1"></i>Kamerayı Kapat
                  </button>
                </div>
              </div>
              @* Ekleme satırı *@
              <div class="row g-3 align-items-center">
                <div class="col-md-4">
                  <select id="stockSelect" style="width:100%">
                    <option value=""></option>
                  </select>
                  <div id="productMessage" class="form-text text-danger mt-1"></div>
                </div>
                <div class="col-md-2">
                  <input type="number" id="lineQty" class="form-control" value="1" min="1" placeholder="Adet" />
                </div>
                <div class="col-md-3">
                  <input type="number" id="linePrice" class="form-control" step="0.01" min="0" placeholder="Alış Fiyatı" />
                </div>
                <div class="col-md-3">
                  <button type="button" id="addLineBtn" class="btn btn-primary w-100">
                    <i class="ri-add-line me-1"></i>Ekle
                  </button>
                </div>
              </div>
            </div>
          </div>

          @* Satır Tablosu *@
          <div class="table-responsive mb-0">
            <table class="table table-bordered table-sm align-middle js-lines-table" id="linesTable">
              <thead class="table-light">
                <tr>
                  <th>Ürün</th>
                  <th class="text-center" style="width:80px">Adet</th>
                  <th class="text-end" style="width:130px">Alış Fiyatı</th>
                  <th class="text-center" style="width:80px">KDV %</th>
                  <th class="text-end" style="width:130px">Ara Toplam</th>
                  <th class="text-end" style="width:120px">KDV</th>
                  <th class="text-end" style="width:130px">Toplam</th>
                  <th style="width:50px"></th>
                </tr>
              </thead>
              <tbody id="linesBody">
                <tr id="emptyRow">
                  <td colspan="8" class="text-center text-body-secondary py-4">
                    <i class="ri-inbox-line me-1"></i>Henüz ürün eklenmedi.
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          @* Tutar Özeti *@
          <div class="d-flex justify-content-end mt-2 mb-4">
            <div class="order-totals-card">
              <div class="order-totals-row">
                <span>Ara Toplam</span>
                <span id="subTotal">0,00 ₺</span>
              </div>
              <div class="order-totals-row">
                <span>Toplam KDV</span>
                <span id="vatTotal">0,00 ₺</span>
              </div>
              <div class="order-totals-grand">
                <span>Genel Toplam</span>
                <span id="grandTotal">0,00 ₺</span>
              </div>
            </div>
          </div>

          <div id="lineInputs"></div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="ri-save-line me-1"></i>Kaydet
            </button>
            <a asp-action="Purchase" class="btn btn-outline-secondary">İptal</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@* Yeni ürün modal *@
<div class="modal fade" id="newProductModal" tabindex="-1" aria-labelledby="newProductModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="newProductModalLabel">
          <i class="ri-add-box-line me-1"></i>Stokta Tanımsız Ürün Ekle
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
      </div>
      <div class="modal-body">
        <p class="text-body-secondary small mb-3">
          Bu ürün stok kartlarında yoksa buradan tanımlayıp faturaya ekleyebilirsiniz. Ürün kaydı fatura kaydedildiğinde oluşturulur.
        </p>
        <div id="newProductMessage" class="alert alert-danger py-2 px-3 small d-none" role="alert"></div>
        <div class="row g-3">
          <div class="col-md-6">
            <label for="newStockCode" class="form-label">Stok Kodu <span class="text-danger">*</span></label>
            <input type="text" id="newStockCode" class="form-control" maxlength="50" />
          </div>
          <div class="col-md-6">
            <label for="newProductName" class="form-label">Ürün Adı <span class="text-danger">*</span></label>
            <input type="text" id="newProductName" class="form-control" maxlength="200" />
          </div>
          <div class="col-md-6">
            <label for="newCategoryId" class="form-label">Kategori <span class="text-danger">*</span></label>
            <select id="newCategoryId" class="form-select mb-2">
              <option value="">Kategori seçin</option>
              @foreach (var category in Model.CategoryOptions)
              {
                <option value="@category.Id">@category.Name</option>
              }
            </select>
            <div class="input-group input-group-sm">
              <input type="text" id="newCategoryName" class="form-control" maxlength="100" placeholder="veya yeni kategori adı yazın" />
              <button type="button" id="createCategoryBtn" class="btn btn-outline-primary">Kategori Ekle</button>
            </div>
            <div id="createCategoryMessage" class="form-text"></div>
          </div>
          <div class="col-md-6">
            <label for="newBarcode" class="form-label">Barkod</label>
            <div class="input-group">
              <input type="text" id="newBarcode" class="form-control" maxlength="50" />
              <button type="button" id="modalScannerBtn" class="btn btn-outline-info" title="Barkod Tara">
                <i class="ri-camera-line"></i>
              </button>
            </div>
            <div id="modalScannerWrapper" class="mt-2" style="display:none;">
              <div id="modal-qr-reader" style="width:100%; max-width:420px; border-radius:0.375rem; overflow:hidden;"></div>
              <button type="button" id="modalStopScannerBtn" class="btn btn-sm btn-outline-secondary mt-2">
                <i class="ri-camera-off-line me-1"></i>Kamerayı Kapat
              </button>
            </div>
          </div>
          <div class="col-md-4">
            <label for="newVatRate" class="form-label">KDV %</label>
            <input type="number" id="newVatRate" class="form-control" value="0" min="0" max="100" step="1" />
          </div>
          <div class="col-md-4">
            <label for="newCriticalStockLevel" class="form-label">Kritik Stok Seviyesi</label>
            <input type="number" id="newCriticalStockLevel" class="form-control" value="5" min="0" />
          </div>
          <div class="col-md-4">
            <label for="newLineQty" class="form-label">Adet <span class="text-danger">*</span></label>
            <input type="number" id="newLineQty" class="form-control" value="1" min="1" />
          </div>
          <div class="col-md-6">
            <label for="newLinePrice" class="form-label">Alış Fiyatı <span class="text-danger">*</span></label>
            <input type="number" id="newLinePrice" class="form-control" step="0.01" min="0" />
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">İptal</button>
        <button type="button" id="addNewProductBtn" class="btn btn-primary">
          <i class="ri-check-line me-1"></i>Faturaya Ekle
        </button>
      </div>
    </div>
  </div>
</div>

@section PageScripts {
  <partial name="_ValidationScriptsPartial" />
  <script src="/vendor/libs/html5-qrcode/html5-qrcode.min.js"></script>
  <script src="~/js/barcode-scanner.js" asp-append-version="true"></script>
  <script src="/js/form-draft-storage.js"></script>
  <script>
    const DRAFT_KEY = 'vrlcrm_draft_purchase';
    const stockOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
      Model.StockOptions,
      new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
    const categoryOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
      Model.CategoryOptions,
      new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
    const categoryNameById = Object.fromEntries(categoryOptions.map(function(c) { return [String(c.id), c.name]; }));
    const stockPrices  = Object.fromEntries(stockOptions.map(function(s) { return [String(s.id), s.price]; }));
    const stockNames   = Object.fromEntries(stockOptions.map(function(s) { return [String(s.id), s.name]; }));
    const stockVatRates = Object.fromEntries(stockOptions.map(function(s) { return [String(s.id), s.vatRate]; }));
    const productCache = new Map();
    stockOptions.forEach(function(s) { productCache.set(String(s.id), s); });

    let lineIndex = 0;
    const lines = new Map();
    let scannedProduct = false;
    let purchaseScanner = null;
    let modalScanner = null;
    const newProductModalEl = document.getElementById('newProductModal');
    const newProductModal = newProductModalEl ? new bootstrap.Modal(newProductModalEl) : null;

    function getCategoryName(categoryId) {
      return categoryId ? (categoryNameById[String(categoryId)] || '') : '';
    }

    function addCategoryOption(category) {
      var select = document.getElementById('newCategoryId');
      var value = String(category.id);
      if (!select.querySelector('option[value="' + value + '"]')) {
        var option = document.createElement('option');
        option.value = value;
        option.textContent = category.name;
        select.appendChild(option);
      }
      categoryNameById[value] = category.name;
      categoryOptions.push({ id: category.id, name: category.name });
      select.value = value;
    }

    function persistDraft() {
      FormDraftStorage.save(DRAFT_KEY, {
        lines: Array.from(lines.entries()),
        lineIndex: lineIndex
      });
    }

    function restoreDraft() {
      const draft = FormDraftStorage.load(DRAFT_KEY);
      if (!draft || !draft.lines) return;
      lines.clear();
      draft.lines.forEach(function(entry) { lines.set(entry[0], entry[1]); });
      lineIndex = draft.lineIndex || lines.size;
      renderLines();
      rebuildHiddenInputs();
      updateTotals();
    }

    FormDraftStorage.bindFormFields(DRAFT_KEY, '#purchaseForm', ['SupplierId', 'InvoiceDate', 'Notes']);

    // ── Toplamlar ───────────────────────────────────────────────────────
    function updateTotals() {
      var sub = 0, vat = 0;
      lines.forEach(function(item) {
        var lineSub = item.qty * item.price;
        vat += lineSub * (item.vatRate / 100);
        sub += lineSub;
      });
      var grand = sub + vat;
      var fmt = function(v) { return v.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' ₺'; };
      document.getElementById('subTotal').textContent = fmt(sub);
      document.getElementById('vatTotal').textContent = fmt(vat);
      document.getElementById('grandTotal').textContent = fmt(grand);
      persistDraft();
    }

    // ── Satır render ────────────────────────────────────────────────────
    function renderLines() {
      var tbody = document.getElementById('linesBody');
      var emptyRow = document.getElementById('emptyRow');
      Array.from(tbody.querySelectorAll('tr:not(#emptyRow)')).forEach(function(r) { r.remove(); });

      if (lines.size === 0) {
        emptyRow.style.display = '';
        return;
      }
      emptyRow.style.display = 'none';

      var fmt = function(v) { return v.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + ' ₺'; };

      lines.forEach(function(item, lineKey) {
        var lineSub = item.qty * item.price;
        var lineVat = lineSub * (item.vatRate / 100);
        var lineTotal = lineSub + lineVat;
        var row = document.createElement('tr');
        row.dataset.lineKey = lineKey;
        var badge = item.isNew ? ' <span class="badge bg-label-info ms-1">Yeni</span>' : '';
        var metaParts = [];
        if (item.code) metaParts.push(item.code);
        if (item.isNew && (item.categoryName || item.categoryId)) {
          metaParts.push(item.categoryName || getCategoryName(item.categoryId));
        }
        var metaHtml = metaParts.length
          ? '<div class="small text-body-secondary">' + metaParts.join(' · ') + '</div>'
          : '';
        row.innerHTML =
          '<td data-label="Ürün">' + item.name + badge + metaHtml + '</td>' +
          '<td data-label="Adet" class="text-center">' + item.qty + '</td>' +
          '<td data-label="Alış Fiyatı" class="text-end">' + fmt(item.price) + '</td>' +
          '<td data-label="KDV %" class="text-center">%' + item.vatRate + '</td>' +
          '<td data-label="Ara Toplam" class="text-end">' + fmt(lineSub) + '</td>' +
          '<td data-label="KDV" class="text-end">' + fmt(lineVat) + '</td>' +
          '<td data-label="Toplam" class="text-end fw-semibold">' + fmt(lineTotal) + '</td>' +
          '<td data-label="" class="text-center"><button type="button" class="btn btn-sm btn-outline-danger remove-line py-0 px-1"><i class="ri-delete-bin-6-line"></i></button></td>';
        tbody.appendChild(row);

        row.querySelector('.remove-line').addEventListener('click', function() {
          lines.delete(lineKey);
          renderLines();
          rebuildHiddenInputs();
          updateTotals();
        });
      });
    }

    // ── Gizli inputlar ──────────────────────────────────────────────────
    function appendHidden(name, value) {
      return '<input type="hidden" name="' + name + '" value="' + String(value ?? '').replace(/"/g, '&quot;') + '" />';
    }

    function rebuildHiddenInputs() {
      var container = document.getElementById('lineInputs');
      container.innerHTML = '';
      lineIndex = 0;
      lines.forEach(function(item) {
        var prefix = 'Lines[' + lineIndex + '].';
        if (item.isNew) {
          container.insertAdjacentHTML('beforeend',
            appendHidden(prefix + 'IsNewProduct', 'true') +
            appendHidden(prefix + 'NewStockCode', item.code) +
            appendHidden(prefix + 'NewProductName', item.name) +
            appendHidden(prefix + 'NewCategoryId', item.categoryId || '') +
            appendHidden(prefix + 'NewCategoryName', item.categoryName || '') +
            appendHidden(prefix + 'NewBarcode', item.barcode || '') +
            appendHidden(prefix + 'NewCriticalStockLevel', item.criticalStockLevel) +
            appendHidden(prefix + 'Quantity', item.qty) +
            appendHidden(prefix + 'UnitPrice', item.price) +
            appendHidden(prefix + 'VatRate', item.vatRate));
        } else {
          container.insertAdjacentHTML('beforeend',
            appendHidden(prefix + 'IsNewProduct', 'false') +
            appendHidden(prefix + 'StockItemId', item.stockId) +
            appendHidden(prefix + 'StockName', item.name) +
            appendHidden(prefix + 'Quantity', item.qty) +
            appendHidden(prefix + 'UnitPrice', item.price) +
            appendHidden(prefix + 'VatRate', item.vatRate));
        }
        lineIndex++;
      });
      persistDraft();
    }

    // ── Ürün ekle ───────────────────────────────────────────────────────
    function addLine() {
      var stockId = tsStock.getValue();
      var qty = parseInt(document.getElementById('lineQty').value, 10);
      var price = parseFloat(document.getElementById('linePrice').value);
      var msg = document.getElementById('productMessage');
      msg.textContent = '';

      if (!stockId || !qty || qty <= 0 || price === undefined || price === null || isNaN(price)) {
        msg.textContent = 'Ürün seçin ve geçerli adet/fiyat girin.';
        return;
      }

      var product = productCache.get(stockId);
      var name = product ? product.name : (stockNames[stockId] || stockId);
      var vatRate = product ? product.vatRate : (stockVatRates[stockId] || 0);
      var lineKey = 'stock:' + stockId;

      var existing = lines.get(lineKey);
      lines.set(lineKey, {
        isNew: false,
        stockId: stockId,
        name: name,
        code: product ? product.stockCode : '',
        qty: (existing ? existing.qty : 0) + qty,
        price: price,
        vatRate: vatRate
      });

      renderLines();
      rebuildHiddenInputs();
      updateTotals();

      tsStock.clear();
      document.getElementById('lineQty').value = 1;
      document.getElementById('linePrice').value = '';

      if (scannedProduct) {
        scannedProduct = false;
        setTimeout(function () { if (purchaseScanner) purchaseScanner.start(); }, 400);
      }
    }

    document.getElementById('addLineBtn').addEventListener('click', addLine);
    document.getElementById('lineQty').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); addLine(); }
    });

    function showNewProductMessage(text) {
      var box = document.getElementById('newProductMessage');
      if (!text) {
        box.classList.add('d-none');
        box.textContent = '';
        return;
      }
      box.textContent = text;
      box.classList.remove('d-none');
    }

    function openNewProductModal(prefillName) {
      showNewProductMessage('');
      if (prefillName) {
        document.getElementById('newProductName').value = prefillName;
      }
      if (newProductModal) {
        newProductModal.show();
        document.getElementById('newStockCode').focus();
      }
    }

    function addNewProductLine() {
      var stockCode = document.getElementById('newStockCode').value.trim();
      var name = document.getElementById('newProductName').value.trim();
      var categoryId = document.getElementById('newCategoryId').value;
      var categoryName = document.getElementById('newCategoryName').value.trim();
      var barcode = document.getElementById('newBarcode').value.trim();
      var vatRate = parseFloat(document.getElementById('newVatRate').value);
      var criticalStockLevel = parseInt(document.getElementById('newCriticalStockLevel').value, 10);
      var qty = parseInt(document.getElementById('newLineQty').value, 10);
      var price = parseFloat(document.getElementById('newLinePrice').value);

      if (!stockCode || !name) {
        showNewProductMessage('Stok kodu ve ürün adı zorunludur.');
        return;
      }
      if (!categoryId && !categoryName) {
        showNewProductMessage('Kategori seçin veya yeni kategori adı girin.');
        return;
      }
      if (!qty || qty <= 0) {
        showNewProductMessage('Geçerli bir adet girin.');
        return;
      }
      if (price === undefined || price === null || isNaN(price) || price < 0) {
        showNewProductMessage('Geçerli bir alış fiyatı girin.');
        return;
      }
      if (isNaN(vatRate) || vatRate < 0) {
        vatRate = 0;
      }
      if (isNaN(criticalStockLevel) || criticalStockLevel < 0) {
        criticalStockLevel = 5;
      }

      var lineKey = 'new:' + stockCode.toLowerCase();
      var existing = lines.get(lineKey);
      lines.set(lineKey, {
        isNew: true,
        name: name,
        code: stockCode,
        categoryId: categoryId || null,
        categoryName: categoryId ? null : categoryName,
        barcode: barcode,
        criticalStockLevel: criticalStockLevel,
        qty: (existing ? existing.qty : 0) + qty,
        price: price,
        vatRate: vatRate
      });

      renderLines();
      rebuildHiddenInputs();
      updateTotals();

      document.getElementById('newStockCode').value = '';
      document.getElementById('newProductName').value = '';
      document.getElementById('newCategoryId').value = '';
      document.getElementById('newCategoryName').value = '';
      document.getElementById('createCategoryMessage').textContent = '';
      document.getElementById('newBarcode').value = '';
      document.getElementById('newVatRate').value = '0';
      document.getElementById('newCriticalStockLevel').value = '5';
      document.getElementById('newLineQty').value = '1';
      document.getElementById('newLinePrice').value = '';
      showNewProductMessage('');
      if (newProductModal) {
        newProductModal.hide();
      }
    }

    document.getElementById('openNewProductBtn').addEventListener('click', function() {
      openNewProductModal('');
    });
    document.getElementById('addNewProductBtn').addEventListener('click', addNewProductLine);

    document.getElementById('createCategoryBtn').addEventListener('click', async function() {
      var nameInput = document.getElementById('newCategoryName');
      var message = document.getElementById('createCategoryMessage');
      var name = nameInput.value.trim();
      message.textContent = '';
      if (!name) {
        message.textContent = 'Kategori adı girin.';
        message.className = 'form-text text-danger';
        return;
      }

      var formData = new FormData();
      formData.append('name', name);
      var tokenInput = document.querySelector('#purchaseForm input[name="__RequestVerificationToken"]');
      if (tokenInput) {
        formData.append('__RequestVerificationToken', tokenInput.value);
      }

      try {
        var response = await fetch('@Url.Action("CreateCategoryQuick", "Invoices")', {
          method: 'POST',
          body: formData
        });
        var payload = await response.json();
        if (!response.ok) {
          message.textContent = payload.error || 'Kategori eklenemedi.';
          message.className = 'form-text text-danger';
          return;
        }

        addCategoryOption(payload);
        nameInput.value = '';
        message.textContent = payload.created
          ? '"' + payload.name + '" kategorisi eklendi ve seçildi.'
          : '"' + payload.name + '" zaten vardı, seçildi.';
        message.className = 'form-text text-success';
      } catch (err) {
        message.textContent = 'Kategori eklenirken hata oluştu.';
        message.className = 'form-text text-danger';
      }
    });

    function showExcelImportMessage(text, type) {
      var box = document.getElementById('excelImportMessage');
      if (!text) {
        box.classList.add('d-none');
        box.textContent = '';
        box.className = 'alert py-2 px-3 small d-none mb-3';
        return;
      }
      box.textContent = text;
      box.className = 'alert py-2 px-3 small mb-3 alert-' + (type || 'info');
      box.classList.remove('d-none');
    }

    function importLinesFromExcel(importedLines) {
      importedLines.forEach(function(line) {
        var lineKey = line.isNew ? ('new:' + line.code.toLowerCase()) : ('stock:' + line.stockId);
        var existing = lines.get(lineKey);
        var merged = {
          isNew: !!line.isNew,
          stockId: line.stockId || null,
          name: line.name,
          code: line.code || '',
          categoryId: line.categoryId || null,
          categoryName: line.categoryName || null,
          barcode: line.barcode || '',
          criticalStockLevel: line.criticalStockLevel || 5,
          qty: (existing ? existing.qty : 0) + line.qty,
          price: line.price,
          vatRate: line.vatRate
        };
        lines.set(lineKey, merged);
      });
      renderLines();
      rebuildHiddenInputs();
      updateTotals();
    }

    document.getElementById('importExcelBtn').addEventListener('click', function() {
      document.getElementById('excelImportInput').click();
    });

    document.getElementById('excelImportInput').addEventListener('change', async function() {
      var file = this.files[0];
      this.value = '';
      if (!file) return;

      showExcelImportMessage('Excel dosyası okunuyor…', 'info');
      var formData = new FormData();
      formData.append('file', file);
      var tokenInput = document.querySelector('#purchaseForm input[name="__RequestVerificationToken"]');
      if (tokenInput) {
        formData.append('__RequestVerificationToken', tokenInput.value);
      }

      try {
        var response = await fetch('@Url.Action("ImportPurchaseExcel", "Invoices")', {
          method: 'POST',
          body: formData
        });
        var payload = await response.json();
        if (!response.ok) {
          var errors = (payload.errors || []).join(' ');
          showExcelImportMessage(errors || 'Excel içe aktarılamadı.', 'danger');
          return;
        }

        importLinesFromExcel(payload.lines || []);
        var warnings = (payload.warnings || []).join(' ');
        showExcelImportMessage(
          (payload.lines || []).length + ' kalem tabloya eklendi.' + (warnings ? ' ' + warnings : ''),
          warnings ? 'warning' : 'success'
        );
      } catch (err) {
        showExcelImportMessage('Excel yüklenirken bir hata oluştu.', 'danger');
      }
    });

    window.openNewProductFromSearch = function(name) {
      openNewProductModal(name || '');
    };

    // ── TomSelect ürün seçimi ───────────────────────────────────────────
    var tsStock = new TomSelect('#stockSelect', {
      valueField: 'id',
      labelField: 'text',
      searchField: 'text',
      create: false,
      placeholder: 'Ürün adı veya kodu ile arayın…',
      options: stockOptions.map(function(s) {
        return { id: String(s.id), text: s.name + (s.stockCode ? ' (' + s.stockCode + ')' : '') };
      }),
      render: {
        no_results: function(data, escape) {
          var term = escape(data.input);
          return '<div class="no-results p-2">' +
            '<div class="mb-2">"' + term + '" için ürün bulunamadı.</div>' +
            '<button type="button" class="btn btn-sm btn-outline-primary w-100" onclick="openNewProductFromSearch(\'' + term.replace(/'/g, "\\'") + '\')">' +
            '<i class="ri-add-box-line me-1"></i>Yeni ürün tanımla</button></div>';
        }
      },
      onChange: function(value) {
        if (value && stockPrices[value] !== undefined) {
          document.getElementById('linePrice').value = stockPrices[value];
        }
      }
    });

    // ── Barkod tarayıcı — ortak iOS-uyumlu modül (/js/barcode-scanner.js) ──
    purchaseScanner = VRLScanner.create({
      readerId: 'qr-reader',
      wrapperId: 'scannerWrapper',
      toggleBtnId: 'scannerBtn',
      stopBtnId: 'stopScannerBtn',
      messageId: 'productMessage',
      idleLabel: '<i class="ri-camera-line me-1"></i>Barkod Tara',
      runningLabel: '<i class="ri-camera-off-line me-1"></i>Kamerayı Kapat',
      onDetected: async function (decodedText) {
        var msg = document.getElementById('productMessage');
        msg.textContent = '';

        var r = await fetch('@Url.Action("LookupBarcode", "Orders")' + '?barcode=' + encodeURIComponent(decodedText));
        if (!r.ok) {
          msg.textContent = 'Barkod bulunamadı: ' + decodedText;
          openNewProductModal('');
          document.getElementById('newBarcode').value = decodedText;
          return;
        }

        var product = await r.json();
        var key = String(product.id);
        productCache.set(key, product);

        tsStock.clearOptions();
        tsStock.addOption({ id: key, text: product.name + (product.stockCode ? ' (' + product.stockCode + ')' : '') });
        tsStock.setValue(key, true);
        document.getElementById('linePrice').value = product.price;

        scannedProduct = true;

        var qtyInput = document.getElementById('lineQty');
        qtyInput.value = 1;
        qtyInput.select();
        qtyInput.focus();
      }
    });

    // Modal içindeki (yeni ürün) barkod tarayıcı — ayrı bir örnek.
    modalScanner = VRLScanner.create({
      readerId: 'modal-qr-reader',
      wrapperId: 'modalScannerWrapper',
      toggleBtnId: 'modalScannerBtn',
      stopBtnId: 'modalStopScannerBtn',
      idleLabel: '<i class="ri-camera-line"></i>',
      runningLabel: '<i class="ri-camera-off-line"></i>',
      onDetected: function (decodedText) {
        document.getElementById('newBarcode').value = decodedText;
      }
    });

    // Modal kapanınca kamera açık kalmasın.
    if (newProductModalEl) {
      newProductModalEl.addEventListener('hidden.bs.modal', function () {
        if (modalScanner) modalScanner.stop();
      });
    }

    document.getElementById('purchaseForm').addEventListener('submit', function(e) {
      var supplierEl = document.querySelector('#purchaseForm [name="SupplierId"]');
      var supplierError = document.getElementById('supplierError');
      if (!supplierEl || !supplierEl.value) {
        e.preventDefault();
        supplierError.classList.remove('d-none');
        supplierEl.focus();
        return false;
      }
      supplierError.classList.add('d-none');
      FormDraftStorage.clear(DRAFT_KEY);
    });

    restoreDraft();
  </script>
  <script>
  (function () {
    const d = window.driver && window.driver.js && window.driver.js.driver;
    if (!d) return;
    const tour = d({
      animate: true, smoothScroll: true, allowClose: true,
      overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
      nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
      showProgress: true, progressText: '{{current}} / {{total}}',
      steps: [
        { element: '#purchaseForm select[name="SupplierId"]', popover: { title: 'Tedarikçi Seçimi', description: 'Malı aldığınız tedarikçiyi seçin. Fatura kaydedilince tedarikçi cari hesabı (borcunuz) bu tutar kadar artar.', side: 'bottom' } },
        { element: '#scannerBtn', popover: { title: 'Barkod Tara', description: 'Kamerayı açar. Gelen ürünün barkodunu okutun — ürün otomatik seçilir.', side: 'bottom' } },
        { element: '#openNewProductBtn', popover: { title: 'Stokta Tanımsız Ürün', description: 'Stok kartında olmayan ürünleri popup ile tanımlayıp faturaya ekleyebilirsiniz. Ürün kaydı fatura kaydedilince oluşur.', side: 'bottom' } },
        { element: '#stockSelect', popover: { title: 'Manuel Ürün Seçimi', description: 'Mevcut stok kartlarından arama yapın. Bulunamazsa "Yeni ürün tanımla" seçeneği çıkar.', side: 'bottom' } },
        { element: '#lineQty', popover: { title: 'Miktar', description: 'Tedarikçiden kaç adet geldiğini girin.', side: 'bottom' } },
        { element: '#linePrice', popover: { title: 'Alış Fiyatı', description: 'Bu partinin alış fiyatı. Stok değer hesabında kullanılır.', side: 'bottom' } },
        { element: '#addLineBtn', popover: { title: 'Kaleme Ekle', description: 'Ürünü faturaya ekler.', side: 'bottom' } },
        { element: '#linesTable', popover: { title: 'Fatura Kalemleri', description: 'Eklenen ürünler listelenir. Genel toplam KDV dahil otomatik hesaplanır.', side: 'top' } },
        { element: 'button[type="submit"]', popover: { title: 'Faturayı Kaydet', description: 'Kaydedince seçilen ürünlerin stoğu artar, tedarikçi cari hesabınız artar.', side: 'top' } }
      ]
    });
    document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
  })();
  </script>
}
