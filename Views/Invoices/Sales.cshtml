@model IReadOnlyList<Invoice>
@{
  ViewData["Title"] = "Satış Faturaları";
}

<div class="card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
    <h5 class="mb-0">Satış Faturaları</h5>
    <div class="d-flex gap-2 align-items-center">
      <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
        <i class="ri-question-line"></i>
      </button>
      <a asp-action="CreateSales" class="btn btn-primary btn-sm">Yeni Satış Faturası</a>
    </div>
  </div>
  <div class="card-body pb-0">
    <partial name="_TableToolbar" />
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover js-data-table">
      <thead>
        <tr>
          <th>Fatura No</th>
          <th>Müşteri</th>
          <th>Tarih</th>
          <th>Tutar</th>
          <th>Durum</th>
          <th>İşlemler</th>
        </tr>
      </thead>
      <tbody>
        @if (!Model.Any())
        {
          <tr><td colspan="6" class="text-center py-5 text-body-secondary">Henüz satış faturası yok.</td></tr>
        }
        else
        {
          @foreach (var invoice in Model)
          {
            <tr class="@(invoice.IsActive ? "" : "table-secondary")">
              <td><strong>@invoice.InvoiceNumber</strong></td>
              <td>@(invoice.Customer?.FullName ?? "-")</td>
              <td>@invoice.InvoiceDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
              <td>@invoice.TotalAmount.ToString("N2") ₺</td>
              <td><partial name="_StatusBadge" model="invoice.IsActive" /></td>
              <td>
                <a asp-action="Details" asp-route-id="@invoice.Id" class="btn btn-sm btn-outline-primary">Detay</a>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

@section PageScripts {
<script>
(function () {
  const d = window.driver && window.driver.js && window.driver.js.driver;
  if (!d) return;
  const tour = d({
    animate: true, smoothScroll: true, allowClose: true,
    overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
    nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
    showProgress: true, progressText: '{{current}} / {{total}}',
    steps: [
      {
        element: '.js-data-table',
        popover: {
          title: 'Satış Faturaları',
          description: 'Tüm satış faturaları burada listelenir. Faturayı iptal etmek stok ve müşteri bakiyesini geri alır.',
          side: 'top'
        }
      },
      {
        element: '.js-search-input',
        popover: {
          title: 'Hızlı Arama',
          description: 'Fatura numarası veya müşteri adıyla arama yapın.',
          side: 'bottom'
        }
      },
      {
        element: 'a[href*="CreateSales"]',
        popover: {
          title: 'Yeni Satış Faturası',
          description: 'Satış faturası oluşturunca seçilen ürünlerin stok miktarı düşer, müşteri cari hesabı artar.',
          side: 'left'
        }
      }
    ]
  });
  document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
})();
</script>
}
