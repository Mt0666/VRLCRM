@model Invoice
@{
  ViewData["Title"] = "Fatura Detayı";
  var typeText = Model.InvoiceType == InvoiceType.Sales ? "Satış Faturası" : "Alış Faturası";
}

<div class="row g-6">
  <div class="col-xl-10">
    <div class="card">
      <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h5 class="mb-1">@Model.InvoiceNumber</h5>
          <small class="text-body-secondary">@typeText</small>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a asp-action="ExportPdf" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">PDF</a>
          <a asp-action="ExportExcel" asp-route-id="@Model.Id" class="btn btn-outline-success btn-sm">Excel</a>
          <a asp-action="@(Model.InvoiceType == InvoiceType.Sales ? "Sales" : "Purchase")" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
          @if (Model.IsActive)
          {
            <form asp-action="Deactivate" asp-route-id="@Model.Id" asp-route-returnAction="@(Model.InvoiceType == InvoiceType.Sales ? "Sales" : "Purchase")" method="post" onsubmit="return confirm('Faturayı pasife almak istediğinize emin misiniz?');">
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-outline-danger btn-sm">Pasife Al</button>
            </form>
          }
        </div>
      </div>
      <div class="card-body">
        <div class="row g-4 mb-6">
          @if (Model.InvoiceType == InvoiceType.Sales)
          {
            <div class="col-md-3"><strong>Müşteri:</strong> @(Model.Customer?.FullName ?? "-")</div>
          }
          else
          {
            <div class="col-md-3"><strong>Tedarikçi:</strong> @(Model.Supplier?.CompanyName ?? "-")</div>
            @if (Model.Supplier is not null)
            {
              <div class="col-md-3"><strong>Tedarikçi Borcu:</strong> @Model.Supplier.Balance.ToString("N2") ₺</div>
            }
          }
          <div class="col-md-3"><strong>Tarih:</strong> @Model.InvoiceDate.ToLocalTime().ToString("dd.MM.yyyy")</div>
          <div class="col-md-3"><strong>Toplam:</strong> @Model.TotalAmount.ToString("N2") ₺</div>
          <div class="col-md-3"><strong>Durum:</strong> <partial name="_StatusBadge" model="Model.IsActive" /></div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
          <p class="mb-4"><strong>Not:</strong> @Model.Notes</p>
        }
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>Ürün</th>
                <th>Adet</th>
                <th>Birim Fiyat</th>
                <th>Toplam</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var line in Model.Lines)
              {
                <tr>
                  <td>@line.StockItem.Name</td>
                  <td>@line.Quantity</td>
                  <td>@line.UnitPrice.ToString("N2") ₺</td>
                  <td>@line.LineTotal.ToString("N2") ₺</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
