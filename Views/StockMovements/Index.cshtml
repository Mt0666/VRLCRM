@model IReadOnlyList<StockMovement>
@{
  ViewData["Title"] = "Stok Hareketleri";
}

<div class="card">
  <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-3">
    <h5 class="mb-0">Stok Hareketleri</h5>
    <button id="page-tour-btn" class="btn btn-sm btn-outline-secondary" title="Sayfayı Tanı">
      <i class="ri-question-line"></i>
    </button>
  </div>
  <div class="card-body pb-0">
    <partial name="_TableToolbar" />
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover js-data-table">
      <thead>
        <tr>
          <th>Tarih</th>
          <th>Ürün</th>
          <th>Tür</th>
          <th>Miktar</th>
          <th>Kaynak</th>
          <th>Not</th>
        </tr>
      </thead>
      <tbody>
        @if (!Model.Any())
        {
          <tr><td colspan="6" class="text-center py-5 text-body-secondary">Henüz stok hareketi yok.</td></tr>
        }
        else
        {
          @foreach (var movement in Model)
          {
            <tr>
              <td>@movement.MovementDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
              <td>@movement.StockItem.Name</td>
              <td>
                @if (movement.MovementType == StockMovementType.In)
                {
                  <span class="badge bg-label-success">Giriş</span>
                }
                else
                {
                  <span class="badge bg-label-danger">Çıkış</span>
                }
              </td>
              <td>@movement.Quantity</td>
              <td>
                @(movement.ReferenceType switch
                {
                  StockMovementReferenceType.Invoice => "Fatura",
                  StockMovementReferenceType.Order   => "Sipariş",
                  StockMovementReferenceType.Manual  => "Manuel",
                  _                                  => movement.ReferenceType.ToString()
                }) #@movement.ReferenceId
              </td>
              <td>@(movement.Notes ?? "-")</td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>

@section PageScripts {
<script>
(function () {
  const d = window.driver && window.driver.js && window.driver.js.driver;
  if (!d) return;
  const tour = d({
    animate: true, smoothScroll: true, allowClose: true,
    overlayOpacity: 0.4, stagePadding: 6, stageRadius: 8,
    nextBtnText: 'İleri →', prevBtnText: '← Geri', doneBtnText: 'Tamam',
    showProgress: true, progressText: '{{current}} / {{total}}',
    steps: [
      { element: '.js-data-table', popover: { title: 'Stok Hareketleri', description: 'Her fatura ve sipariş işlemi stokta bir hareket kaydı oluşturur. "Giriş" alış faturası, "Çıkış" satış faturası demektir. Fatura iptali de burada kayıt oluşturur.', side: 'top' } },
      { element: '.js-search-input', popover: { title: 'Hızlı Arama', description: 'Ürün adı veya referans numarasıyla arama yapın.', side: 'bottom' } },
      { element: 'th:nth-child(3)', popover: { title: 'Hareket Türü', description: 'Giriş: stok arttı (alış faturası). Çıkış: stok azaldı (satış faturası veya iptal).', side: 'bottom' } },
      { element: 'th:nth-child(5)', popover: { title: 'Referans', description: 'Bu hareketi tetikleyen fatura veya sipariş numarası. İlgili belgeye doğrudan gidebilirsiniz.', side: 'bottom' } }
    ]
  });
  document.getElementById('page-tour-btn').addEventListener('click', () => tour.drive());
})();
</script>
}
