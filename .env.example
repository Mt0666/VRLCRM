# Kopyala: cp .env.example .env
# Gizli değerleri SADECE .env dosyasında tut (.env git'e gitmez)
# Not: Şifrede ; veya $ karakteri olsa bile sorun olmaz (SqlConnectionStringBuilder kullanılıyor)

MSSQL_SA_PASSWORD=degistir-guclu-bir-sifre-yaz
SeedData__AdminPassword=degistir-guclu-admin-sifresi
SeedData__AdminEmail=admin@vrlcrm.local
SQL_PORT=1433
ASPNETCORE_ENVIRONMENT=Production

# Yerel HTTPS (Caddy + Let's Encrypt) — telefona sertifika yukleme gerekmez
CRM_HOSTNAME=crm.metevarol.com.tr
ACME_EMAIL=admin@vrlcrm.local
# Cloudflare > My Profile > API Tokens > Edit zone DNS
CLOUDFLARE_API_TOKEN=
# Bos birakilirsa setup scripti otomatik bulur
LOCAL_LAN_IP=

# Cloudflare Zero Trust > Networks > Tunnels > Configure > Install connector > Docker
# Token'i buraya yapistirin. Bos birakirsaniz tunnel servisi baslatilmaz.
CLOUDFLARE_TUNNEL_TOKEN=
